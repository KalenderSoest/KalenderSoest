{#
/**
 * @file
 * Twitter Bootstrap v5 Sliding pagination control implementation.
 *
 * View that can be used with the pagination module
 * from the Twitter Bootstrap CSS Toolkit
 * http://getbootstrap.com/components/#pagination
 *
 * @author Pablo Díez <pablodip@gmail.com>
 * @author Jan Sorgalla <jsorgalla@gmail.com>
 * @author Artem Ponomarenko <imenem@inbox.ru>
 * @author Artem Zabelin <artjomzabelin@gmail.com>
 */
#}
{% if query.filter is defined %}
    {% set frontendUrlQ = '?' in route ? route ~ '&' : route ~ '?' %}
    {% if pageCount > 1 %}
        <nav aria-label="Pagination" style="margin-top: 1rem;">
        <ul class="pagination">

        {% if previous is defined %}
            <li class="page-item">
                <a class="page-link" href="{{ frontendUrlQ ~  pageParameterName ~ '=' ~ previous  ~ query.filter  }}">&laquo;&nbsp;{{ 'Previous'|trans }}</a>
            </li>
        {% else %}
            <li class="page-item disabled" aria-disabled="true">
                <span class="page-link">&laquo;&nbsp;{{ 'Previous'|trans }}</span>
            </li>
        {% endif %}

        {% if startPage > 1 %}
            <li class="page-item">
                <a class="page-link" href="{{ frontendUrlQ ~  pageParameterName ~ '=1'  ~ query.filter }}">1</a>
            </li>
            {% if startPage == 3 %}
                <li class="page-item">
                    <a class="page-link" href="{{ frontendUrlQ ~  pageParameterName ~ '=2'  ~ query.filter }}">2</a>
                </li>
            {% elseif startPage != 2 %}
            <li class="page-item disabled" aria-disabled="true">
                <span class="page-link">&hellip;</span>
            </li>
            {% endif %}
        {% endif %}

        {% for page in pagesInRange %}
            {% if page != current %}
                <li class="page-item">
                    <a class="page-link" href="{{ frontendUrlQ ~  pageParameterName ~ '=' ~ page ~ query.filter }}">{{ page }}</a>
                </li>
            {% else %}
                <li class="page-item active" aria-current="page">
                    <span class="page-link">{{ page }}</span>
                </li>
            {% endif %}

        {% endfor %}

        {% if pageCount > endPage %}
            {% if pageCount > (endPage + 1) %}
                {% if pageCount > (endPage + 2) %}
                    <li class="page-item disabled" aria-disabled="true">
                        <span class="page-link">&hellip;</span>
                    </li>
                {% else %}
                    {% set pn = pageCount -1 %}
                    <li class="page-item">
                        <a class="page-link" href="{{ frontendUrlQ ~  pageParameterName ~ '=' ~ pn  ~ query.filter  }}">{{ pn }}</a>
                    </li>
                {% endif %}
            {% endif %}
            <li class="page-item">
                <a class="page-link" href="{{ frontendUrlQ ~  pageParameterName ~ '=' ~ pageCount  ~ query.filter  }}">{{ pageCount }}</a>
            </li>
        {% endif %}

        {% if next is defined %}
            <li class="page-item">
                <a class="page-link" href="{{ frontendUrlQ ~  pageParameterName ~ '=' ~ next  ~ query.filter }}">{{ 'Next'|trans }}&nbsp;&raquo;</a>
            </li>
        {% else %}
            <li class="page-item disabled" aria-disabled="true">
                <span class="page-link">{{ 'Next'|trans }}&nbsp;&raquo;</span>
            </li>
        {% endif %}
        </ul>
        </nav>
      {% endif %}
{% else %}
{% if pageCount > 1 %}
    <nav aria-label="Pagination" style="margin-top: 1rem;">
    <ul class="pagination">

    {% if previous is defined %}
        <li class="page-item">
            <a class="page-link" href="{{ path(route, query|merge({(pageParameterName): previous})) }}">&laquo;&nbsp;{{ 'Previous'|trans }}</a>
        </li>
    {% else %}
        <li class="page-item disabled" aria-disabled="true">
            <span class="page-link">&laquo;&nbsp;{{ 'Previous'|trans }}</span>
        </li>
    {% endif %}

    {% if startPage > 1 %}
        <li class="page-item">
            <a class="page-link" href="{{ path(route, query|merge({(pageParameterName): 1})) }}">1</a>
        </li>
        {% if startPage == 3 %}
            <li class="page-item">
                <a class="page-link" href="{{ path(route, query|merge({(pageParameterName): 2})) }}">2</a>
            </li>
        {% elseif startPage != 2 %}
        <li class="page-item disabled" aria-disabled="true">
            <span class="page-link">&hellip;</span>
        </li>
        {% endif %}
    {% endif %}

    {% for page in pagesInRange %}
        {% if page != current %}
            <li class="page-item">
                <a class="page-link" href="{{ path(route, query|merge({(pageParameterName): page})) }}">{{ page }}</a>
            </li>
        {% else %}
            <li class="page-item active" aria-current="page">
                <span class="page-link">{{ page }}</span>
            </li>
        {% endif %}

    {% endfor %}

    {% if pageCount > endPage %}
        {% if pageCount > (endPage + 1) %}
            {% if pageCount > (endPage + 2) %}
                <li class="page-item disabled" aria-disabled="true">
                    <span class="page-link">&hellip;</span>
                </li>
            {% else %}
                {% set pn = pageCount -1 %}
                <li class="page-item">
                    <a class="page-link" href="{{ path(route, query|merge({(pageParameterName): (pn)})) }}">{{ pn }}</a>
                </li>
            {% endif %}
        {% endif %}
        <li class="page-item">
            <a class="page-link" href="{{ path(route, query|merge({(pageParameterName): pageCount})) }}">{{ pageCount }}</a>
        </li>
    {% endif %}

    {% if next is defined %}
        <li class="page-item">
            <a class="page-link" href="{{ path(route, query|merge({(pageParameterName): next})) }}">{{ 'Next'|trans }}&nbsp;&raquo;</a>
        </li>
    {% else %}
        <li class="page-item disabled" aria-disabled="true">
            <span class="page-link">{{ 'Next'|trans }}&nbsp;&raquo;</span>
        </li>
    {% endif %}
    </ul>
    </nav>
{% endif %}
{% endif %}
