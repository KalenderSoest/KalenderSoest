{% extends 'Kalender/' ~ custom ~ 'termine.html.twig' %}
{% block dfx_termin %}	
<div itemscope itemtype="http://schema.org/Event" class="row fx-blank">
{% if strImgPrev is not null %}
    <div class="col-{{ colXsImg }} col-sm-{{ colSmImg }} col-md-{{ colMdImg }}">
   		<span class="dfx-image" itemprop="image">{{ strImgPrev|raw }}</span>
   	</div>	
		<div class="col-{{ colXsText }} col-sm-{{ colSmText }} col-md-{{ colMdText }}">
	{%  else %}
		<div class="col-12">
	{% endif %}
		<h5 itemprop="name" class="dfx-titel-liste-dreizeilig"><a href="{{ mehrUrl }}">{{ titel|raw }}</a></h5>
                {% if termin.subtitel != NULL %}
                    <div class="dfx-subtitel-liste-dreizeilig">{{'subtitel-fe'|trans}}{{ termin.subtitel }} </div>
                {% endif %}
		<div>{% if strDate !='' %}<span class="dfx-datum-liste-dreizeilig">{{ strDate }}</span>{% endif %}{% if strTime !='' %}<span class="dfx-zeit-liste-dreizeilig">{% if strDate !='' %}{{ tz }}{% endif %} {{ strTime }}</span>{% endif %}{{ strMetadate|raw }}</div>
		<div itemprop="location" itemscope itemtype="http://schema.org/Place">
			{% if strLokal !='' %}
				<span itemprop="name" class="dfx-lokal-liste-dreizeilig">{{ strLokal|raw }}</span>
			{% endif %}
			{% if strOrt !='' and strLokal !='' %} 
			    {{ tz }} 
			{% endif %}
			{% if strOrt !='' or strStrasse !='' %}
				<span itemprop="address" itemscope itemtype="http://schema.org/PostalAddress">
    			    {% if strOrt !='' %} <span class="dfx-ort-liste-dreizeilig">{{ strOrt|raw }}</span>{% endif %}{% if strStrasse !='' %}<span class="dfx-strasse-liste-dreizeilig">, {{ strStrasse|raw }}</span>{% endif %}
		    	</span>
		     {% endif %}
		     {{ strMapLink|raw }} {{ strGeoItemprop|raw }}
		 </div>
    	 <a style="float:right" href="{{ mehrUrl }}">{{ 'details'|trans }} <i class="fa-solid fa-chevron-right"></i></a>
	</div>
{{ strMapWindow|raw }}
{{ strMapClose|raw }}
</div>
{%  endblock %}
