    		{{'pflichtfelder'|trans}}
    	</div>
    </div>
{% endblock dfx_termin_detail %}
{% block dfx_konf %}
	<div id="dfx_konf" data-cssfile="{{ cssFile }}" data-mapkey="{{ mapkey }}" data-tileserver="{{ tileserver }}" data-mapset="{{ mapset }}" data-copyright="{{ copyright }}" data-tpl="form" data-nav-pos="{{ konf.navPos }}" data-nav-width="{{ konf.navWidth }}"  data-nav-liste="{{ konf.navListe }}" data-nav-detail="0" style="display: none"></div>
{% endblock dfx_konf %}
	{% block javascript_onload %}
		(function() {
			var datefix = document.getElementById('datefix');
			var form = document.querySelector('form[name="termine"]');
			var beschreibung = document.getElementById('termine_beschreibung');
			var lead = document.getElementById('termine_lead');
			var online = document.getElementById('termine_online');
		var imageInfo = document.getElementById('imageInfoBlock');
		var imgCopyCheck = document.getElementById('termine_imgcopycheck');
		var imageFile = document.getElementById('termine_imageFile');

		{% if konf.maxLengthBeschreibung > 0 %}
		if (datefix) {
			datefix.addEventListener('focusout', function(e) {
				if (e.target && e.target.id === 'termine_beschreibung') {
					if (beschreibung && beschreibung.value.length > {{ konf.maxLengthBeschreibung }} ) {
						alert("Der Text für die Beschreibung ist mit " + beschreibung.value.length + " Zeichen länger als die erlaubten {{ konf.maxLengthBeschreibung }} Zeichen");
					}
				}
			});
			datefix.addEventListener('submit', function(e) {
				var f = e.target.closest('form[name="termine"]');
				if (!f) return;
				if (beschreibung && beschreibung.value.length > {{ konf.maxLengthBeschreibung }} + 10) {
					alert("Der Text für die Beschreibung ist mit " + beschreibung.value.length + " Zeichen länger als die erlaubten {{ konf.maxLengthBeschreibung }} Zeichen.\n\nVor dem erneuten Absenden ist ein Klick ein anderes Formularfeld nötig !.");
					if (typeof lengthChecked !== 'undefined') { lengthChecked = false; }
					e.preventDefault();
				}
			});
		}
		{% endif %}
		{% if konf.maxLengthLead > 0 %}
		if (datefix) {
			datefix.addEventListener('focusout', function(e) {
				if (e.target && e.target.id === 'termine_lead') {
					if (lead && lead.value.length > {{ konf.maxLengthLead }} ) {
						alert("Der Text für die Kurzfassung ist mit " + lead.value.length + " Zeichen länger als die erlaubten {{ konf.maxLengthLead }} Zeichen");
					}
				}
			});
			datefix.addEventListener('submit', function(e) {
				var f = e.target.closest('form[name="termine"]');
				if (!f) return;
				if (lead && lead.value.length > {{ konf.maxLengthLead }} ) {
					alert("Der Text für die Kurzfassung ist mit " + lead.value.length + " Zeichen länger als die erlaubten {{ konf.maxLengthLead }} Zeichen.\n\nVor dem erneuten Absenden ist ein Klick ein anderes Formularfeld nötig !.");
					if (typeof lengthChecked !== 'undefined') { lengthChecked = false; }
					e.preventDefault();
				}
			});
		}
		{% endif %}
		{%  if konf.feldRegion == 1 %}
		var region = document.getElementById('termine_region');
		if (region) {
			region.addEventListener('change', function(){
				var rid = region.value ? region.value : 0;
				fetch(url + "/js/kalender/json/region/" + rid)
					.then(function(res){ return res.json(); })
					.then(function (jdata) {
						var idOrt = document.getElementById('termine_idOrt');
						var ort = document.getElementById('termine_ort');
						if (!idOrt) return;
						idOrt.innerHTML = '';
						var arrlen = jdata.length;
						if (arrlen === 1) {
							var opt = document.createElement('option');
							opt.value = jdata[0].id;
							opt.textContent = jdata[0].ort;
							idOrt.appendChild(opt);
							if (ort) ort.value = jdata[0].ort;
						} else {
							var optEmpty = document.createElement('option');
							optEmpty.value = '';
							optEmpty.textContent = 'Ort wählen';
							idOrt.appendChild(optEmpty);
							for (var i = 0; i < arrlen; i++) {
								var opt2 = document.createElement('option');
								opt2.value = jdata[i].id;
								opt2.textContent = jdata[i].ort;
								idOrt.appendChild(opt2);
							}
						}
					});
			});
		}
		{% endif %}
		{%  if konf.feldOrtdb == 1 %}
		var idOrtSel = document.getElementById('termine_idOrt');
		if (idOrtSel) {
			idOrtSel.addEventListener('change', function(){
				var regionVal = document.getElementById('termine_region');
				if (parseInt(idOrtSel.value || '0', 10) > 0 && regionVal && regionVal.value !== null) {
					fetch(url + "/js/kalender/json/ort/" + idOrtSel.value)
						.then(function(res){ return res.json(); })
						.then(function (jdata) {
							var regionEl = document.getElementById('termine_region');
							var plzEl = document.getElementById('termine_plz');
							var ortEl = document.getElementById('termine_ort');
							if (regionEl) regionEl.value = jdata.rid;
							if (plzEl) plzEl.value = jdata.plz;
							if (ortEl) ortEl.value = jdata.ort;
						});
				}
			});
		}
		{% endif %}

		if (datefix) {
			datefix.addEventListener('click', function(e){
				var btn = e.target.closest('#termincheck');
				if (!btn) return;
				var datumVon = document.getElementById('termine_datum_von');
				if (datumVon && datumVon.value.length > 0) {
					fetch(url + "/admin/termine/json/check/" + datumVon.value)
						.then(function(res){ return res.text(); })
						.then(function(html){
							var liste = document.getElementById('terminliste');
							if (liste) liste.innerHTML = html;
						});
				}
			});
		}

		function toggleOnline() {
			var hideEls = document.querySelectorAll('.hideOnline');
			var showEls = document.querySelectorAll('.showOnline');
			if (online && online.checked) {
				hideEls.forEach(function(el){ el.style.display = 'none'; });
				showEls.forEach(function(el){ el.style.display = ''; });
			} else {
				hideEls.forEach(function(el){ el.style.display = ''; });
				showEls.forEach(function(el){ el.style.display = 'none'; });
			}
		}
		if (online) {
			toggleOnline();
			online.addEventListener('click', toggleOnline);
		}
		if (imageInfo) imageInfo.style.display = 'none';
		if (imageFile) {
			imageFile.addEventListener('change', function(){
				if (imageFile.value !== null) {
					if (imageInfo) imageInfo.style.display = '';
					if (imgCopyCheck) imgCopyCheck.required = true;
				} else {
					if (imageInfo) imageInfo.style.display = 'none';
					if (imgCopyCheck) imgCopyCheck.required = false;
				}
			});
		}
			if (form) {
				form.addEventListener('reset', function(){
					if (imageInfo) imageInfo.style.display = 'none';
					if (imgCopyCheck) imgCopyCheck.required = false;
				});
			}

			(function patchDatumSeriePicker() {
				if (window.__dfxDatumSeriePatchApplied) return;
				window.__dfxDatumSeriePatchApplied = true;

				var stopLegacyChangeReinit = function(e) {
					if (e.target && e.target.matches && e.target.matches('#termine_datumSerie')) {
						e.stopImmediatePropagation();
					}
				};
				document.addEventListener('change', stopLegacyChangeReinit, true);

				var initPatchedPicker = function() {
					var input = document.getElementById('termine_datumSerie');
					if (!input || !window.flatpickr) return;

					document.querySelectorAll('.dfx-serie-picker-btn').forEach(function(btn) {
						btn.remove();
					});

					if (input._flatpickr) {
						try { input._flatpickr.destroy(); } catch (e) {}
					}

					var selected = (input.value || '')
						.split(',')
						.map(function(v) { return v.trim(); })
						.filter(function(v) { return v.length > 0; });

					var locale = (window.flatpickr.l10ns && window.flatpickr.l10ns.de) ? window.flatpickr.l10ns.de : undefined;
					window.flatpickr(input, {
						mode: 'multiple',
						dateFormat: 'Y-m-d',
						conjunction: ', ',
						locale: locale,
						allowInput: false,
						clickOpens: true,
						closeOnSelect: false,
						defaultDate: selected,
						onChange: function() {
							var datumVon = document.getElementById('termine_datum_von');
							if (datumVon) datumVon.required = false;
						}
					});
				};

				window.dfxInitDatumSeriePicker = function() {
					if (typeof window.dfxLoadFlatpickr === 'function') {
						window.dfxLoadFlatpickr().then(function(fp) {
							if (fp) initPatchedPicker();
						});
						return;
					}
					if (window.flatpickr) initPatchedPicker();
				};

				window.dfxInitDatumSeriePicker();
			})();
		})();
	{% endblock %}
