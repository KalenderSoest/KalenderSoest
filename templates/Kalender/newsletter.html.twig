{% extends 'Kalender/base_newsletter.html.twig' %}
{% block dfx_termin -%}
<tr>
 <td colspan="2">	
	<h4 style="font-size: 18px;font-family: Arial,Helvetica,sans-serif">{{ termin.titel|raw }}</h4>
 </td>
</tr>
<tr>
 <td valign="top">{{ strImgPrev|raw }}</td>
 <td valign="top">
 	<p style="color: #333333; font-size: 13px; line-height: 1.644; font-family: Arial,Helvetica,sans-serif">
 	{% if strDate !='' %}{{ strDate }}{% endif %}{% if strTime !='' %}{% if strDate !='' %}{{ tz }}{% endif %} {{ strTime }}{% endif %}<br>
	{% if strLokal !='' %}{{ strLokalText|raw }}{% endif %}{% if strOrt !='' and strLokal !='' %} {{ tz }} {% endif %}{% if strOrt !='' %}  {{ strOrt|raw }}{% endif %}{% if strStrasse !='' %}, {{ strStrasse|raw }}{% endif %} <br><br>
    {{  strTextLead|raw }}</p>
    <p>{{ strEintritt }}</p>
    <p style="color: #333333; font-size: 13px; line-height: 1.644; font-family: Arial,Helvetica,sans-serif; text-align: right">{{ rowInfo|raw }} {{ mehrLink|raw }}</p>
 </td>  
</tr>
<tr>
 <td colspan="2">	
	<hr style="border: none; height: 1px; color: #ccc; background-color: #ccc;">
 </td>
</tr>
{%  endblock %}