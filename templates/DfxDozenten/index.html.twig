{% extends 'Admin/' ~ backend ~ 'base_admin.html.twig' %}
{% block title 'Dozenten' %}
{% block pageheader 'Dozenten' %}
{% block subheader 'Dozentenliste' %}

{% block footer %}
    
	
	
	

{% endblock footer %}

{% block body -%}
    <a href="{{ path('dozent_new') }}">Dozenten hinzufügen</a><br />
    <table class="table table-striped">
       <thead>
            <tr>
            	<th>ID</th>
            	<th>Name</th>
                <th colspan="2">Actions</th>
            </tr>
        </thead>
        <tbody>
		{% for entity in pagination %}
            <tr>
            	<td>{{ entity.id }}</td>
                <td>{{ entity.name }}</td>
                    
				<td><a href="{{ path('dozent_edit', { 'id': entity.id }) }}"><i class="fa-solid fa-pen-to-square"> </i></a></td>
                <td><a class="delete" title="Datensatz {{ entity.name }} löschen" href="{{ path('dozent_delete', { 'id': entity.id }) }}"><i class="fa-solid fa-trash-can"> </i></a></td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    <div class="navigation">
    	{{ knp_pagination_render(pagination) }}
	</div>
    <a href="{{ path('dozent_new') }}">Dozent hinzufügen</a>
{% endblock %}  

