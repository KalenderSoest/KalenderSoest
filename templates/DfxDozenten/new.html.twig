{% extends 'Admin/' ~ backend ~ 'base_admin.html.twig' %}
{% block title 'Dozent' %}
{% block pageheader 'Dozent eingeben' %}
{% block footer %}
{
{% endblock footer %}
{% block javascript_onload %}
{% endblock %}
{% block body -%}
    {{ form_start(form) }}
    <div class="row">
	    <div class="col-sm-12 col-md-9">
	    {{ form_row(form.name) }}
	    </div>
    </div>
    <div class="row">
	    <div class="col-sm-12 col-md-9">
	    {{ form_row(form.strasse) }}
	    </div>
    </div>
    <div class="row">
        {%  if konf.feldNat == 1 %}
            <div class="col-sm-4 col-md-1">
                {{ form_row(form.nat) }}
            </div>
        {% endif %}
        <div class="col-sm-8 col-md-2">
            {{ form_row(form.plz) }}
        </div>
        <div class="col-sm-12 col-md-6">
            {{ form_row(form.ort) }}
        </div>
    </div>
    <div class="row">
    	<div class="col-sm-12 col-md-6">
    		{{ form_row(form.telefon) }}
    	</div>
    </div>
    <div class="row">
    	<div class="col-sm-12 col-md-6">
    	 	{{ form_row(form.email) }}
    	</div>
    </div>
   <div class="row">
    	<div class="col-sm-12 col-md-6">
    		 {{ form_row(form.www) }}
    	</div>
   </div>
   <div class="row">
    	<div class="col-sm-12 col-md-9">
       		{{ form_row(form.zusatz) }}
       	</div>
    </div>
    <div class="row">
    	<div class="col-sm-12 col-md-4">
           
    	</div>
    	<div class="col-sm-12 col-md-2">
    		
    	</div>
    </div>
    <div class="row">
    	<div class="col-sm-12 col-md-6">
    	    {{ form_row(form.location) }}
    	</div>
    </div>
    <div class="row">
    	<div class="col-sm-12 col-md-6">
    	    {{ form_row(form.veranstalter) }}
    	</div>
    </div> 
    <div class="row">
		  <div class="col-6">
		  {{ form_row(form.submit) }}
		  </div>
		  <div class="col-6">
		  {{ form_row(form.reset) }}
		  </div>
		
	</div>
    {{ form_row(form._token) }}
    {{ form_end(form, {'render_rest': false}) }}
    <div><br /><a href="{{ path('admin_dozenten') }}">Zurück zur Liste ohne zu speichern</a></div>
{% endblock %}


