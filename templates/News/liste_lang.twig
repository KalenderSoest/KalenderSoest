{% extends 'News/' ~ custom ~ 'news.html.twig' %}
{% block dfx_artikel %}
<div itemscope itemtype="http://schema.org/Event" >	
<div class="row">
	<div itemprop="name" class="col-9 md-10"><h4 class="dfx-titel-liste-kompakt">{{ titel|raw }}</h4></div>
	<div class="col-3 md-2 text-right">{{ rowInfo|raw }} {{ printLinks|raw }}</div>
</div>
<hr class="terminlinie">
<div class="row">
{% if artikel.subtitel != NULL %}
    <div class="col-12 dfx-detail-subtitel">{{'subtitel-fe'|trans}}{{ artikel.subtitel }} </div>
{% endif %}
{% if artikel.img !=NULL %}
	<div itemprop="image" class="col-12 col-sm-6">
   		{{ strImgPrev|raw }}
   	</div>
	<div class="col-12 col-sm-6">
  {% else %}
   	<div class="col-12">
  {% endif %}
		<div>
			{% if strDate !='' %}<span class="dfx-datum-liste">{{ strDate }}</span>{% endif %}{{ strMetadate|raw }}<br>
			{% if strText !='' %}<div itemprop="description" class="dfx-text">{{ strText|raw }}</div>{% endif %}
			{% if rowSocial !='' %}<div class="dfx-social">{{ rowSocial|raw }}</div>{%  endif %}
	   	
   		</div>
	</div>
</div>
</div>
<hr class="terminlinie-bottom">
{%  endblock %}