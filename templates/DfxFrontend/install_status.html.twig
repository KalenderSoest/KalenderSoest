{% extends 'Admin/base_admin.html.twig' %}
{% block title %}Datefix Installation{% endblock %}
{% block pageheader %}INSTALLATION{% endblock %}
{% block subheader %}Systemstatus{% endblock %}
{% block body %}
    <div class="row">
        <div class="col-lg-12">
            {% for message in app.flashes('success') %}
                <div class="alert alert-success">{{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('warning') %}
                <div class="alert alert-warning">{{ message }}</div>
            {% endfor %}
            <p>Erkannter Modus: <strong>{{ state.mode }}</strong></p>
            {% if state.mode == 'missing_vendor' %}
                <div class="alert alert-danger">`vendor` fehlt. Bitte zuerst <code>composer install --no-dev --optimize-autoloader</code> ausführen.</div>
            {% elseif state.mode == 'repair_config' %}
                <div class="alert alert-warning">Konfiguration oder Datenbankzugang ist unvollständig oder fehlerhaft.</div>
            {% elseif state.mode == 'fresh_install' %}
                <div class="alert alert-success">Leere Datenbank erkannt. Neuinstallation ist möglich.</div>
            {% elseif state.mode == 'fresh_install_pending_setup' %}
                <div class="alert alert-success">Schema ist angelegt. Die Basisdaten für die Neuinstallation können jetzt eingerichtet werden.</div>
            {% elseif state.mode == 'migrate_existing' and has_required_migration_actions %}
                <div class="alert alert-info">Bestehende Datenbank mit Tabellen erkannt. Migrations-/Updatepfad ist erforderlich.</div>
            {% endif %}
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12">
            <h3>Ablaufplan</h3>
            <ul class="list-group mb-4">
                {% for step in plan %}
                    <li class="list-group-item">
                        <strong>{{ step.title }}</strong><br>
                        {{ step.description }}
                        {% if step.done %}
                            <div class="text-success mt-2">Erledigt</div>
                        {% elseif step.action_route %}
                            <div class="mt-2"><a class="btn btn-primary btn-sm" href="{{ path(step.action_route, step.action_params|default({})) }}">{{ step.action_label }}</a></div>
                        {% elseif step.hint is defined and step.hint %}
                            <div class="text-muted mt-2">{{ step.hint }}</div>
                        {% endif %}
                    </li>
                {% endfor %}
            </ul>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-6">
            <h3>Composer</h3>
            <ul class="list-group mb-4">
                <li class="list-group-item">`composer.json`: {{ state.composer.composer_json_exists ? 'vorhanden' : 'fehlt' }}</li>
                <li class="list-group-item">`composer.lock`: {{ state.composer.composer_lock_exists ? 'vorhanden' : 'fehlt' }}</li>
                <li class="list-group-item">`vendor/autoload.php`: {{ state.composer.vendor_autoload_exists ? 'vorhanden' : 'fehlt' }}</li>
                <li class="list-group-item">PHP-Anforderung: {{ state.composer.php_requirement ?: 'unbekannt' }}</li>
                <li class="list-group-item">Symfony-Anforderung: {{ state.composer.symfony_requirement ?: 'unbekannt' }}</li>
            </ul>
        </div>
        <div class="col-lg-6">
            <h3>Umgebung</h3>
            <ul class="list-group mb-4">
                <li class="list-group-item">.env-Dateien: {{ state.env.files ? state.env.files|length : 0 }}</li>
                <li class="list-group-item">APP_ENV: {{ state.env.app_env ?: 'nicht gesetzt' }}</li>
                <li class="list-group-item">DATABASE_URL: {{ state.env.database_url ? 'vorhanden' : 'fehlt' }}</li>
                <li class="list-group-item">MAILER_DSN: {{ state.env.mailer_dsn ? 'vorhanden' : 'fehlt' }}</li>
            </ul>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-6">
            <h3>Datenbank</h3>
            <ul class="list-group mb-4">
                <li class="list-group-item">Datenbankname: {{ state.database.database_name ?: 'unbekannt' }}</li>
                <li class="list-group-item">Verbindung: {{ state.database.connectable ? 'ok' : 'fehlerhaft' }}</li>
                <li class="list-group-item">Tabellenanzahl: {{ state.database.table_count }}</li>
                <li class="list-group-item">Datefix-Tabellen erkannt: {{ state.database.has_datefix_tables ? 'ja' : 'nein' }}</li>
                {% if state.database.error %}
                    <li class="list-group-item text-danger">{{ state.database.error }}</li>
                {% endif %}
            </ul>
        </div>
        <div class="col-lg-6">
            <h3>Migrationschecks</h3>
            <ul class="list-group mb-4">
                <li class="list-group-item">
                    <strong>JSON-Mehrfachfelder</strong>: {{ state.database.checks.array_json.message|default('nicht geprüft') }}
                    {% if state.database.checks.array_json.affected_fields is defined and state.database.checks.array_json.affected_fields is not empty %}
                        <div class="small text-muted">
                            {% for field in state.database.checks.array_json.affected_fields %}
                                {{ field.table }}.{{ field.column }}{% if field.rows_needing_migration is defined %} (Datensätze: {{ field.rows_needing_migration }}){% endif %}{% if not loop.last %}, {% endif %}
                            {% endfor %}
                        </div>
                    {% endif %}
                </li>
                <li class="list-group-item">
                    <strong>`toGroup`</strong>: {{ state.database.checks.to_group.message }}
                    {% if state.database.checks.to_group.column_type is defined and state.database.checks.to_group.column_type %}
                        <div class="small text-muted">Spaltentyp: {{ state.database.checks.to_group.column_type }}, Datensätze: {{ state.database.checks.to_group.non_empty_rows|default(0) }}</div>
                    {% endif %}
                </li>
                <li class="list-group-item">
                    <strong>Legacy-Medien</strong>: {{ state.database.checks.legacy_media.message }}
                    {% if state.database.checks.legacy_media.existing_columns is defined %}
                        <div class="small text-muted">Spalten: {{ state.database.checks.legacy_media.existing_columns is not empty ? state.database.checks.legacy_media.existing_columns|join(', ') : 'keine' }}, Datensätze: {{ state.database.checks.legacy_media.rows_with_data|default(0) }}</div>
                    {% endif %}
                </li>
                <li class="list-group-item">
                    <strong>Passwort-/Login-Struktur</strong>: {{ state.database.checks.legacy_passwords.message }}
                    {% if state.database.checks.legacy_passwords.has_salt is defined %}
                        <div class="small text-muted">
                            salt: {{ state.database.checks.legacy_passwords.has_salt ? 'ja' : 'nein' }},
                            moderne Login-Felder: {{ state.database.checks.legacy_passwords.has_modern_login_fields ? 'ja' : 'nein' }}
                        </div>
                    {% endif %}
                </li>
            </ul>
        </div>
        <div class="col-lg-6">
            <h3>Verzeichnisse</h3>
            <ul class="list-group mb-4">
                {% for dir in state.directories %}
                    <li class="list-group-item">
                        {{ dir.path }}:
                        {% if not dir.exists %}
                            fehlt
                        {% elseif dir.writable %}
                            vorhanden und schreibbar
                        {% else %}
                            vorhanden, aber nicht schreibbar
                        {% endif %}
                    </li>
                {% endfor %}
            </ul>
        </div>
    </div>
{% endblock %}
