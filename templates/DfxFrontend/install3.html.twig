{% extends 'Admin/base_admin.html.twig' %}
{% block title %}Datefix Installation{% endblock %}
{% block pageheader %}INSTALLATION{% endblock %}
{% block subheader %}Datenbank-Tabellen anlegen{% endblock %}
{% block body %}
    <div class="row">
        <div class="col-lg-12">
            <div class="mb-4">
                {{ msg|raw }}
            </div>
            <div class="d-flex gap-2">
                {% if continue_route is defined and continue_route %}
                    <a class="btn btn-primary" href="{{ path(continue_route, continue_params|default({})) }}">{{ continue_label|default('Weiter') }}</a>
                {% endif %}
                <a class="btn btn-outline-secondary" href="{{ path('dfx_install_status') }}">Zurück zum Status</a>
            </div>
        </div>
    </div>
{% endblock %}
