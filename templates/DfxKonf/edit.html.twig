{% extends 'Admin/' ~ backend ~ 'base_admin.html.twig' %}
{% block title 'Konfiguration' %}
{% block pageheader 'Konfiguration bearbeiten' %}
{% set strSubheader = entity.titel is not null ? entity.titel : entity.user.kunde.kunde %}
{% block subheader strSubheader  %}
{% block footer %}

{% endblock footer %}
{% block body -%}
{{ form_start(edit_form) }}
    <fieldset class="step-7">
        <legend>URI, Logo, Banner, HTML Umfeld</legend>
        <p>Tragen Sie in die Frontend-Url die Seite ein, in die Ihr Einbaucode eingebunden ist. Soll der Standalone-Kalender verwendet werden, lassen Sie die Einstellung unverändert. Geben Sie auch die Urls zu ihrer Datenschutzerklärung und Impressum ein.</p>
        <div class="row">
            <div class="col-md-4">
                {{ form_row(edit_form.frontendUrl) }}
            </div>
            <div class="col-md-4">
                {{ form_row(edit_form.datenschutzUrl) }}
            </div>
            {% if is_granted('ROLE_SUPER_ADMIN') %}
                <div class="col-md-4">
                    {{ form_row(edit_form.impressumUrl) }}
                </div>
            {% endif %}
        </div>
        <p>Das Logo wird in den PDF-Exporten verwendet - sofern eines hochgeladen wurde. Logos werden automatisch auf eine Breite von 300 Pixel bzw Höhe von 150 Pixel verkleinert. Das Banner wird ausschließlich in der Standalone-Version ( {{ datefix_url ~ '/kalender/' ~ entity.id }} verwendet und automatisch auf die Größe von 1200 x 350 Pixel beschnitten.) </p>
        <div class="row">
            <div class="col-sm-12 col-md-4">
                {{ form_row(edit_form.imageFile) }}
            </div>
            <div class="col-sm-12 col-md-2">
                {%  if entity.imgLogo is not null %}
                    {% set strImgPrev = '<img class="dfx-image" src="'~ asset('/images/dfx/' ~ entity.id ~ '/' ~ entity.imgLogo) | imagine_filter('thumb') ~ '" />' %}
                {% else %}
                    {% set strImgPrev = NULL %}
                {%  endif %}
                {{ strImgPrev|raw }}
            </div>
            <div class="col-sm-12 col-md-4">
                {{ form_row(edit_form.imageFile2) }}
            </div>
            <div class="col-sm-12 col-md-2">
                {%  if entity.imgBanner is not null %}
                    {% set strImgPrev2 = '<img class="dfx-image" src="'~ asset('/images/dfx/' ~ entity.id ~ '/' ~ entity.imgBanner) | imagine_filter('thumb') ~ '" />' %}
                {% else %}
                    {% set strImgPrev2 = NULL %}
                {%  endif %}
                {{ strImgPrev2|raw }}
            </div>
        </div>
        <p>Sie haben hier die Möglichkeit für die Standalone-Version ( {{ datefix_url ~ '/kalender/' ~ entity.id }}) erklärenden HTML-Code einzufügen. Er erscheint zwischen Banner und Veranstaltungskalender bzw unterhalb der Veranstaltungsdaten.  </p>
        <div class="row">
            <div class="col-sm-12 col-md-6">
                {{ form_row(edit_form.htmlHead) }}
            </div>
            <div class="col-sm-12 col-md-6">
                {{ form_row(edit_form.htmlFooter) }}
            </div>
        </div>
        <p>Der Eintrag unter "Titel" wird in der Standalone-Version ( {{ datefix_url ~ '/kalender/' ~ entity.id }} für die Anzeige im Browser-Tab verwendet. Die Adresse wird für die Footer der Systemmails, den Adressbereich der PDF-Dokumente und bei fehlendem Link zum Impressum im automatisch generiertem Impressum verwendet. Fehlen Angaben in diesem Feld, werden automatisch die Kundendaten verwendet.</p>
        <div class="row">
            <div class="col-sm-12 col-md-6">
                {{ form_row(edit_form.titel) }}
            </div>
            <div class="col-sm-9 col-md-6">
                {{ form_row(edit_form.adresse) }}
            </div>
        </div>


    </fieldset>
    <hr>
<fieldset class="step-0">
    <legend>Rubriken</legend>
     {% if entity.inheritMeta == 1 or entity.inheritGroup == 1 %}
     	<div class="row">
    		<div class="col-12">
    			Die Rubriken werden vom übergeordneten Meta- oder Gruppenkalender bezogen.
    		</div>
    	</div>
	{% else %}
    	{{ form_errors(edit_form.rubriken) }}
     	<div class="row" id="rubrik-fields-list" data-prototype='<input type="text" class="form-control" id="datefix_backendbundle_dfxkonf_rubriken___name__" name="datefix_backendbundle_dfxkonf[rubriken][]" value="" />'>
		 {% for rubrikField in edit_form.rubriken %}
    		<div class="col-12 col-sm-4 col-md-3" style="margin-bottom: 10px;">
        		{{ form_errors(rubrikField) }}
        		{{ form_widget(rubrikField, { 'attr': {'class': 'form-control'} }) }}
    		</div>
		 {% endfor %}
		</div>
		<div class="row">
    	<div class="col-12 col-sm-4 col-md-3">
    		<a href="#" id="add-rubrik">Rubrik hinzufügen</a><br /><br />
    	</div>
    </div>
    {% endif %}
    {% if zielgruppe %}
    <legend>Zielgruppen</legend>
        {% if entity.inheritZielgruppenMeta == 1 or entity.inheritZielgruppenGroup == 1 %}
            <div class="row">
                    <div class="col-12">
                            Die Zielgruppen werden vom übergeordneten Meta- oder Gruppenkalender bezogen.
                    </div>
            </div>
         {% else %}
            {{ form_errors(edit_form.zielgruppen) }}
            <div class="row" id="zielgruppe-fields-list" data-prototype='<input type="text" class="form-control" id="datefix_backendbundle_dfxkonf_zielgruppen___name__" name="datefix_backendbundle_dfxkonf[zielgruppen][]" value="" />'>
                {% for zielgruppenField in edit_form.zielgruppen %}
                    <div class="col-12 col-sm-4 col-md-3" style="margin-bottom: 10px;">
                        {{ form_errors(zielgruppenField) }}
                        {{ form_widget(zielgruppenField, { 'attr': {'class': 'form-control'} }) }}
                    </div>
                 {% endfor %}
            </div>
            <div class="row">
                <div class="col-12 col-sm-4 col-md-3">
                    <a href="#" id="add-zielgruppe">Zielgruppe hinzufügen</a>
                </div>
            </div>
        {% endif %}
    {% endif %}
</fieldset>
    <hr>
<fieldset class="step-1">
    <legend>Gliederung, Gestaltung und Farben</legend>
    <div class="row">
    	<div class="col-12 col-sm-4 col-md-3">
