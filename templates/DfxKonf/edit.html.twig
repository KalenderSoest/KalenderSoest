       <div class="col-12">
            <div class="d-flex align-items-center flex-nowrap gap-2">
                {{ form_widget(edit_form.useMap) }}
                {{ form_label(edit_form.useMap, null, { 'label_attr': { 'class': 'mb-0' } }) }}
                &nbsp;/&nbsp;{{ form_label(edit_form.initZoom, null, { 'label_attr': { 'class': 'mb-0' } }) }}
                {{ form_widget(edit_form.initZoom, { 'attr': { 'size': 2, 'maxlength': 2, 'class': 'form-control form-control-sm d-inline-block', 'style': 'width: 6ch; min-width: 6ch;' } }) }}
			</div>
	   </div>
	</div>
</fieldset>
    <hr>
<fieldset class="step-4-2">
