    	</div>

    </div>
    <div class="row align-items-start">
        <div class="col-12 col-md-4">
            <strong>&nbsp;</strong>
        </div>
    	<div class="col-12 col-md-4">
    		<strong>Bildgröße Vorschaubilder in Listen</strong>
    	</div>
    	<div class="col-12 col-md-4">
    	    <strong>Bildgröße in Detailansichten</strong>
