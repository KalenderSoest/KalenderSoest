    	<div class="col-12 col-sm-4 col-md-3">
			{{ form_row(edit_form.showLokal) }}
    	</div>
    </div>
</fieldset>
    <hr>
<fieldset class="step-2">
    <legend>Kalender, Suchfunktion, Filterelemente</legend>
    <div class="row">
        <div class="col-12 col-sm-6 col-md-3">
			{{ form_row(edit_form.navPos) }}
