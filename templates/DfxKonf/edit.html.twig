    	</div>
    	<div class="col-sm-4 col-md-3">
    		{{ form_row(edit_form.inheritGroup) }}
    	</div>
     </div>
     <div class="row">
       	<div class="col-sm-4 col-md-3">
    		{{ form_row(edit_form.inheritZielgruppenMeta) }}
    	</div>
    	<div class="col-sm-4 col-md-3">
    		{{ form_row(edit_form.inheritZielgruppenGroup) }}
    	</div>
     </div>


 </fieldset>
<hr>
<div class="row">
	  <div class="col-6">
	  	{{ form_row(edit_form.submit) }}
	  </div>
	  <div class="col-6">
	  	{{ form_row(edit_form.reset) }}
	  </div>
</div>
{{ form_row(edit_form._token) }}
{{ form_end(edit_form, {'render_rest': false}) }}

{% endblock body %}
{% block javascript_onload %}
	{% if entity.inheritMeta != 1 and entity.inheritGroup != 1 %}
	if(rubrikCount == 0){
		addField();
		addField();
		addField();
		addField();
	}
	(function() {
		var btn = document.getElementById('add-rubrik');
		if (!btn) return;
		btn.addEventListener('click', function(e) {
			e.preventDefault();
			addField();
		});
	})();
	{% endif %}

    {% if zielgruppe %}
        {% if entity.inheritZielgruppenMeta != 1 and entity.inheritZielgruppenGroup != 1 %}
			if(zielgruppenCount == 0){
				addZielgruppenField();
				addZielgruppenField();
				addZielgruppenField();
				addZielgruppenField();
			}
			(function() {
				var btn = document.getElementById('add-zielgruppe');
				if (!btn) return;
				btn.addEventListener('click', function(e) {
					e.preventDefault();
					addZielgruppenField();
				});
			})();
		{% endif %}
    {% endif %}


{% endblock javascript_onload %}
{% block javascript_functions %}
    {% if entity.inheritMeta != 1 and entity.inheritGroup != 1 %}
	function addField(){
            var rubrikList = document.getElementById('rubrik-fields-list');
            if (!rubrikList) return null;
            var newWidget = rubrikList.getAttribute('data-prototype');
            newWidget = newWidget.replace(/__name__/g, parseInt(rubrikCount, 10));
            rubrikCount++;
            var newLi = document.createElement('div');
            newLi.className = 'col-12 col-sm-4 col-md-3';
            newLi.style.marginBottom = '10px';
            newLi.innerHTML = newWidget;
            rubrikList.appendChild(newLi);
            return newLi;
        }
    {% endif %}
    {% if zielgruppe %}
        {% if entity.inheritZielgruppenMeta != 1 and entity.inheritZielgruppenGroup != 1 %}
            function addZielgruppenField(){
                var zielgruppenList = document.getElementById('zielgruppe-fields-list');
                if (!zielgruppenList) return null;
                var newWidgetZielgruppen = zielgruppenList.getAttribute('data-prototype');
                newWidgetZielgruppen = newWidgetZielgruppen.replace(/__name__/g, parseInt(zielgruppenCount, 10));
                zielgruppenCount++;
                var newLi = document.createElement('div');
                newLi.className = 'col-12 col-sm-4 col-md-3';
                newLi.style.marginBottom = '10px';
                newLi.innerHTML = newWidgetZielgruppen;
                zielgruppenList.appendChild(newLi);
                return newLi;
            }
        {% endif %}
    {% endif %}

{% endblock javascript_functions %}
{% block javascript_var %}
	var rubrikCount = '{{ edit_form.rubriken|length }}';
        var zielgruppenCount = '{{ edit_form.zielgruppen|length }}';
{% endblock javascript_var %}

