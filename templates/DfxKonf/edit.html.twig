</fieldset>
    <hr>

{% if is_granted('ROLE_SUPER_ADMIN') %}
    {% set hidefield ='' %}
{% else %}
    {% set hidefield ="style=display:none" %}
{% endif %}
<fieldset class="step-6">
    <legend>Archivierung, Meta- und Gruppenkalender</legend>
    <div class="row">
        <div class="col-sm10 col-md-5">
            <strong>Tage bis zum Entfernen nicht archivierter Termine nach Ablauf:</strong><br>
        </div>
        <div class="col-sm2 col-md-1">
            {{ form_row(edit_form.archivTage) }}
        </div>

    </div>
    <div class="row">

    	<div class="col-sm-4 col-md-3" {{ hidefield }}>
    		{{ form_row(edit_form.isMeta) }}
    	</div>
    	<div class="col-sm-4 col-md-3" {{ hidefield }}>
    		{{ form_row(edit_form.isGroup) }}
    	</div>
    	<div class="col-sm-4 col-md-3" {{ hidefield }}>
            Diesen Kalender einem oder mehreren Gruppenkalendern zuordnen
