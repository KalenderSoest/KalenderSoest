<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Der Veranstaltungskalender für Städte, Gemeinden, Theater, Kulturveranstalter, Vereine und Jedermann.">
    <meta name="author" content="Pool Online Internetservice">
    <meta name="copyright" content="Pool Online Internetservice, Nördlingen">
    <meta name="keywords" content="Veranstaltungskalender, Eventkalender, Homepagetools, Webmastertools, Homepage, Webkalender">
    <meta NAME="robots" content="INDEX, FOLLOW">

    <title>Administration :: {% block title %}{% endblock %}</title>
    <link href="{{ asset('css/bootstrap.css') }}" rel="stylesheet">
    <link href="{{ asset('css/datefix_fe.css') }}" rel="stylesheet">
    <link href="{{ asset('fontawesome/css/all.min.css') }}" rel="stylesheet" >
    <link href="{{ asset('fontawesome/css/v4-shims.min.css') }}" rel="stylesheet" >
    <link href="https://cdn.jsdelivr.net/npm/suneditor@2.47.8/dist/css/suneditor.min.css" rel="stylesheet">
    <style>
        .dfx-nav .navbar-brand img{
            margin-top: -12px;
        }
    </style>
    {% block head %}{% endblock %}
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-light dfx-nav fixed-top" role="navigation">
    <div class="container">
        <a class="navbar-brand" href="{{ path('home') }}">
            <img src="{{ asset('images/logo_400.png') }}" width="300" height="" alt="Logo">
        </a>
        <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#dfx-navbar-collapse-1" aria-controls="dfx-navbar-collapse-1" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- Collect the nav links, forms, and other content for toggling -->
        <div class="collapse navbar-collapse justify-content-lg-end" id="dfx-navbar-collapse-1">
            {% if is_granted('ROLE_USER') %}
                <div class="d-flex flex-column align-items-stretch align-items-lg-end admin-nav-wrap">
                    <!-- Logout/Impersonation Section -->
                    <ul class="navbar-nav mb-0 d-flex flex-column flex-lg-row align-items-start align-items-lg-center gap-1 gap-lg-2 admin-nav-top">
                        {% if is_granted('IS_IMPERSONATOR') %}
                            <li class="nav-item">
                                <span class="">Sie sind eingelogt als User {{ app.user.username }} !!!</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="{{ impersonation_exit_path(path('admin')) }}">
                                    <i class="fa-solid fa-arrow-right-from-bracket"></i> Exit User {{ app.user.username }}
                                </a>
                            </li>
                        {% else %}
                            <li class="nav-item d-none d-lg-block invisible">
                                <span class="">Dummy</span>
                            </li>
                            <li class="nav-item d-none d-lg-block invisible">
                                <a class="nav-link" href="#">
                                    <i class="fa-solid fa-arrow-right-from-bracket"></i> Dummy
                                </a>
                            </li>
                        {% endif %}
                    </ul>

                    <!-- Main Navigation -->
                    <ul class="navbar-nav nav-pills admin-nav-main">
                    <!-- Home Button -->
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('admin') }}">
                            <i class="fa-solid fa-house"></i>
                        </a>
                    </li>

                    <!-- Termindaten Dropdown -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Termindaten
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="{{ path('termine_new') }}">Termin eingeben</a></li>
                            <li><a class="dropdown-item" href="{{ path('admin_termine') }}">Termine bearbeiten</a></li>
                            <li><a class="dropdown-item" href="{{ path('admin_anmeldungen') }}">Anmeldungen</a></li>
                            <li><a class="dropdown-item" href="{{ path('admin_karten') }}">Kartenbestellungen</a></li>
                            <li><a class="dropdown-item" href="{{ path('io') }}">Terminimport/-export</a></li>
                        </ul>
                    </li>

                    <!-- News/Seiten Dropdown -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            News/Seiten
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="{{ path('artikel_new') }}">Artikel eingeben</a></li>
                            <li><a class="dropdown-item" href="{{ path('admin_news') }}">Artikel bearbeiten</a></li>
                        </ul>
                    </li>

                    <!-- Datenbanken Dropdown -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Datenbanken
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="{{ path('admin_locations') }}">Locations</a></li>
                            <li><a class="dropdown-item" href="{{ path('admin_veranstalter') }}">Veranstalter</a></li>
                            {% if is_granted('ROLE_ADMIN') %}
                                <li><a class="dropdown-item" href="{{ path('admin_region') }}">Regionen</a></li>
                                <li><a class="dropdown-item" href="{{ path('admin_orte') }}">Orte</a></li>
                            {% endif %}
                        </ul>
                    </li>

                    {% if is_granted('ROLE_ADMIN') %}
                        <!-- Konfiguration Dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Konfiguration
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="{{ path('admin_dfxkonf') }}">Einstellungen</a></li>
                                <li><a class="dropdown-item" href="{{ path('admin_user') }}">Benutzer</a></li>
                                <li><a class="dropdown-item" href="{{ path('box_edit') }}">Terminbox</a></li>
                                {% if is_granted('ROLE_SUPER_ADMIN') %}
                                    <li><a class="dropdown-item" href="{{ path('superadmin') }}">Kalender-Verwaltung</a></li>
                                    {% if dfx_version == 'multi' %}
                                        <li><a class="dropdown-item" href="{{ path('register') }}">Kalender hinzufügen</a></li>
                                    {% endif %}
                                {% endif %}
                            </ul>
                        </li>

                        <!-- Hilfe Dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Hilfe
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="{{ path('dfx_einbau') }}">Einbau</a></li>
                                <li><a class="dropdown-item" href="{{ asset('handbuch_installation_betrieb.pdf') }}" target="_blank">Handbuch</a></li>
                            </ul>
                        </li>
                    {% endif %}
                    <!-- Logout (last item) -->
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_logout') }}">
                            <i class="fa-solid fa-arrow-right-from-bracket"></i> Logout
                        </a>
                    </li>
                    </ul>
                </div>
            {% endif %}
        </div>
        <!-- /.navbar-collapse -->
    </div>
    <!-- /.container -->
</nav>
    <!-- Page Content -->
    <div class="container">

        <!-- Page Heading/Breadcrumbs -->
        <div class="row">
            <div class="col-lg-12">
                <h1 class="mb-3 pb-2 border-bottom">{% block pageheader %}{% endblock %}
                    <small>{% block subheader %}{% endblock %}</small>
                </h1>

            </div>
        </div>
        <!-- /.row -->
        <div id="dfx_be" data-dfx-url="{{ datefix_url }}"></div>
   		 {% block body %}{% endblock %}


        <hr>

        <!-- Footer -->
        <footer>
            <div class="row">
                <div class="col-lg-12">
                    <p>Copyright &copy; POOL ONLINE INTERNETSERVICE 1999 - {{  'now'|date('Y') }}</p>
                </div>
            </div>
        </footer>

    </div>
    <!-- /.container -->

    <script src="{{ asset('js/dfx_functions.js') }}"  type="text/javascript"></script>
    <script src="{{ asset('js/bootstrap.bundle.min.js') }}" type="text/javascript"></script>

    {% block footer %}{% endblock %}
    <script type="text/javascript">
	    {% block javascript_var %}{% endblock %}
	    document.addEventListener('DOMContentLoaded', function() {
            var be = document.getElementById('dfx_be');
            url = be ? be.getAttribute('data-dfx-url') : url;
            document.querySelectorAll('.delete').forEach(function (el) {
                el.addEventListener('click', function (e) {
                    if (!confirm(el.getAttribute('title') + '?')) {
                        e.preventDefault();
                        e.stopPropagation();
                    }
                });
            });
	    	{% block javascript_onload %}{% endblock %}
	    });

	    {% block javascript_functions %}{% endblock %}
    </script>
    <script src="https://cdn.jsdelivr.net/npm/suneditor@2.47.8/dist/suneditor.min.js"></script>
    <script src="{{ asset('js/suneditor-init.js') }}" type="text/javascript"></script>

    <!-- Script to Activate the Carousel -->


</body>

</html>





