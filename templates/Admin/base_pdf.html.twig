<style>
    .pdf-admin-document {
        color: #333;
        font-family: DejaVu Sans, sans-serif;
        font-size: 10pt;
    }

    .pdf-admin-document table {
        width: 100%;
        border-collapse: collapse;
        border-left: 0.5pt solid #999;
        border-bottom: 0.5pt solid #999;
    }

    .pdf-admin-document td {
        font-size: 8pt;
        border-top: 0.5pt solid #999;
        border-right: 0.5pt solid #999;
        padding: 1mm;
        margin: 0;
        vertical-align: top;
    }

    .pdf-admin-document th {
        font-size: 8pt;
        border-top: 0.5pt solid #999;
        border-right: 0.5pt solid #999;
        padding: 1mm;
        margin: 0;
        background-color: #f5f5f5;
        text-align: left;
    }

    .pdf-admin-header {
        margin-bottom: 10mm;
        border-bottom: 1px solid #ccc;
        padding-bottom: 3mm;
    }

    .pdf-admin-header h1 {
        margin: 0;
        font-size: 18pt;
        font-weight: bold;
    }

    .pdf-admin-header small {
        display: block;
        margin-top: 2mm;
        color: #666;
        font-size: 10pt;
        font-weight: normal;
    }
</style>

<div class="pdf-admin-document">
    <div class="pdf-admin-header">
        <h1>
            {% block pageheader %}{% endblock %}
            <small>{% block subheader %}{% endblock %}</small>
        </h1>
    </div>

    {% block body %}{% endblock %}
</div>
