	    	 <a id="getgeodata" data-formname="dfx_location" data-feldstrasse="strasse" href="#">Hole Geodaten aus Adressdaten</a> | <a id="setgeodata" data-formname="dfx_location" data-feldstrasse="strasse" href="#">Hole Geodaten aus Karte</a>
	    	</div>
	   </div>
	   <div class="row">
    		<div class="col-sm-12 col-md-9">
                    <div class="dfx-map-window" id="dfxMap" data-mapkey="{{ mapkey }}" data-tileserver="{{ tileserver }}" data-mapset="{{ mapset }}" data-copyright="{{ copyright }}" data-initbg="{{ initbg }}" data-initlg="{{ initlg }}" data-initzoom="{{ initzoom }}" style="margin-bottom:15px"></div>
	    	</div>
	   </div>
	{% endif %}
