{% extends 'Admin/' ~ backend ~ 'base_admin.html.twig' %}
{% block title 'Locations' %}
{% block pageheader 'Location bearbeiten' %}
{% block subheader entity.name  %}

{% block footer %}
{% if konf.useMap == 1 %}
    <link href="{{ asset('js/leaflet/leaflet.css') }}" rel="stylesheet">
    <script src="{{ asset('js/leaflet/leaflet.js') }}" type="text/javascript"></script>
{% endif %}

{% endblock footer %}
{% block javascript_onload %}
    {%  if konf.feldRegion == 1 %}
    document.addEventListener('change', function(event) {
        var regionSelect = event.target.closest('#dfx_location_region');
        if (!regionSelect) {
            return;
        }

        var rid = regionSelect.value || 0;
        var ortSelect = document.getElementById('dfx_location_idOrt');
        var ortInput = document.getElementById('dfx_location_ort');

        fetch(url + '/js/kalender/json/region/' + rid)
            .then(function(response) {
                return response.json();
            })
            .then(function(jdata) {
                if (!ortSelect) {
                    return;
                }

                ortSelect.innerHTML = '';
                var arrlen = jdata.length;
                if (arrlen === 1) {
                    ortSelect.appendChild(new Option(jdata[0].ort, jdata[0].id));
                    if (ortInput) {
                        ortInput.value = jdata[0].ort;
                    }
                    return;
                }

                ortSelect.appendChild(new Option('Ort wählen', ''));
                for (var i = 0; i < arrlen; i++) {
                    ortSelect.appendChild(new Option(jdata[i].ort, jdata[i].id));
                }
            });
    });
    {% endif %}
    {%  if konf.feldOrtdb == 1 %}
    document.addEventListener('change', function(event) {
        var ortSelect = event.target.closest('#dfx_location_idOrt');
        if (!ortSelect || !(Number(ortSelect.value) > 0)) {
            return;
        }

        fetch(url + '/js/kalender/json/ort/' + ortSelect.value)
            .then(function(response) {
                return response.json();
            })
            .then(function(jdata) {
                var regionInput = document.getElementById('dfx_location_region');
                var plzInput = document.getElementById('dfx_location_plz');
                var ortInput = document.getElementById('dfx_location_ort');

                if (regionInput) {
                    regionInput.value = jdata.rid;
                }
                if (plzInput) {
                    plzInput.value = jdata.plz;
                }
                if (ortInput) {
                    ortInput.value = jdata.ort;
                }
            });
    });
    {% endif %}
{% endblock %}
{% block body -%}
    {{ form_start(form) }}
    <div class="row">
	    <div class="col-sm-12 col-md-9">
	    {{ form_row(form.name) }}
	    </div>
    </div>
    <div class="row">
	    <div class="col-sm-12 col-md-9">
	    {{ form_row(form.strasse) }}
	    </div>
    </div>
    <div class="row">
        {%  if konf.feldOrtdb == 1 %}
            {%  if konf.feldNat == 1 %}
                <div class="col-sm-2 col-md-1">
                    {{ form_row(form.nat) }}
                </div>
            {% endif %}
            {%  if konf.feldRegion == 1 %}
