{% extends 'Admin/base_pdf.html.twig' %}
{% if termin.datum == termin.datumVon %}
	{% set strDate =  termin.datumVon|date('d.m.Y') %}
{% else %}	
	{% set strDate = termin.datumVon|date('m.d.Y') ~ ' bis '|trans ~ termin.datum|date('m.d.Y') %}
{% endif %}	
{% set strTime = termin.zeit != NULL ? "#{ termin.zeit|date('H:i') } Uhr" : "" %}

{% block title 'Anmeldungen' %}
{% block pageheader 'Anmeldungen' %}
{% block subheader "#{ termin.titel|raw ~', ' ~  strDate ~ ' ' ~ strTime }" %}
{% block body -%}
     <table cellspacing="0">
        <thead>
            <tr>
            	<th style="width:80mm">Name, Vorname, Firma/Organisation</th>
            	<th style="width:70mm">Ort</th>
            	<th style="width:10mm;text-align:right">Plätze</th>
            </tr>
        </thead>
        <tbody>
		{% for anmeldung in anmeldungen %}
			 <tr>
                <td>{{ anmeldung.nachname }}, {{ anmeldung.vorname }}{{ anmeldung.org is not null ? ', ' ~ anmeldung.org : '' }}</td>
                <td>{{ anmeldung.ort  }}</td>
                <td style="text-align:right">{{ anmeldung.anzahl  }}</td>
             </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}  
