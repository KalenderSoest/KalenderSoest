{% extends 'Admin/base_admin.html.twig' %}

{% block title %}Bitte einloggen{% endblock %}

{% block body %}
    {% if error %}
        <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}
    {% if app.user %}
        <div class="mb-3">
            Sie sind bereits eingeloggt als User  {{ app.user.username }}, <a href="{{ path('app_logout') }}">Logout</a><br><br>
        </div>
    {% endif %}

    <form action="{{ path('app_login') }}" method="post">
    <div class="row" style="margin-bottom: 24px;">
        <div class="col-md-2 col-sm-4">
            <label for="username"><strong>Usernummer:</strong></label>
            <input type="text" id="username" name="_username" value="{{ last_username }}" class="form-control" autocomplete="username" required autofocus/>
        </div>
        <div class="col-md-2 col-sm-4">
            <label for="password"><strong>Passwort:</strong></label>
            <input type="password" id="password" name="_password" class="form-control" autocomplete="current-password" required/>
        </div>
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

    {#
        Uncomment this section and add a remember_me option below your firewall to activate remember me functionality.
        See https://symfony.com/doc/current/security/remember_me.html

        <div class="checkbox mb-3">
            <label>
                <input type="checkbox" name="_remember_me"> Remember me
            </label>
        </div>
    #}
        <div class="col-md-1 col-sm-4" style="margin-top: 24px;">
            <button class="btn btn btn-primary" type="submit">senden</button>
        </div>
    </div>
</form>
    <p>&nbsp;<br><a href="{{ path('app_forgot_password_request') }}">Passwort vergessen oder zurücksetzen</a></p>
{% endblock %}


