{% extends 'Emails/base_termin.html.twig' %}
{% block body %}
<h3>{{ 'Termineintrag aus dem Internet'|trans }}</h3>
<p>von {{ post.termine.gastVorname }} {{ post.termine.gastNachname }} , {{ post.termine.gastEmail }}<br><br>
 <p>{{ 'Veranstaltung eingetragen'|trans }}.</p>
    <p>
     {% if konf.allowPubAll != 1 %}
     	<p><a href="{{ url('termine_pub' , { 'id': termin.id, 'code':termin.code  })}}">{{ 'Termin veroeffentlichen'|trans }} </a>.</p>
     {% else %}	
     	<p><a href="{{ url('termine_unpub' , { 'id': termin.id, 'code':termin.code  })}}">{{ 'Termin sperren'|trans }} </a>.</p>
     {% endif %}


    <p><a href="{{ url('termine_edit' , { 'id': termin.id, 'code': termin.code  })}}">{{ 'Termin bearbeiten'|trans }} </a>.</p>
    <p><a class="delete" href="{{ url('termine_delete' , { 'id': termin.id, 'code':termin.code  })}}" title='Datensatz "{{ termin.titel }}" löschen'>{{ 'Termin loeschen'|trans }}</a>.</p>
	{% if termin.code is not null %}
        <p>{{ 'Hinweis Serientermin'|trans }}</p>
     {% endif %}post.termine.
<h4>{{ 'Kurzfassung Termineintrag'|trans }}</h4>
<p><strong>{{ termin.titel|raw }}</strong><br>
{{ strDate }} {% if strTime !='' %}{{ strTime }}{% endif %}</p>
<p>
{% if strLokal != NULL %}{{ strLokal|raw }}<br>{% endif %}
{% if strStrasse != NULL %}{{ strStrasse|raw }}<br>{% endif %}
{% if strOrt !=NULL %}{{ strOrt|raw }}<br>{% endif %}
</p>
<p><a href="{{ frontendUrlQ }}dfxpath={{ path('detail', { 'id': termin.id, 'kid': konf.id }) }}">{{ 'termin ansehen'|trans }}</a></p>
{% endblock body %}

