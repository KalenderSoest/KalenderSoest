{% extends 'Emails/base_termin.html.twig' %}
{% block body %}
<h3>{{ 'Termineintrag erfolgreich'|trans }}</h3>
<p>Hallo {{ post.termine.gastVorname }} {{ post.termine.gastNachname }} ,<br><br>
 <p>{{ 'Veranstaltung eingetragen'|trans }}.</p>
    <p>
     {% if konf.allowPubAll != 1 %}
     	{{ 'Freigabe Administrator'|trans }}.
     {% endif %}
     {{ 'Email Administrator'|trans }} {{ konf.user.email }} {{ 'ist unterwegs'|trans }}.</p>
        {% if termin.code is not null %}
        <p>{{ 'Hinweis Serientermin'|trans }}</p>
     {% endif %}
<h4>{{ 'Kurzfassung Termineintrag'|trans }}</h4>
<p><strong>{{ termin.titel|raw }}</strong><br>
{{ strDate }} {% if strTime !='' %}{{ strTime }}{% endif %}</p>
<p>
{% if strLokal != NULL %}{{ strLokal|raw }}<br>{% endif %}
{% if strStrasse != NULL %}{{ strStrasse|raw }}<br>{% endif %}
{% if strOrt !=NULL %}{{ strOrt|raw }}<br>{% endif %}
</p>
<p><a href="{{ frontendUrlQ }}dfxpath={{ path('detail', { 'id': termin.id, 'kid': konf.id }) }}">{{ 'termin ansehen'|trans }}</a></p>
<p><a href="{{ frontendUrlQ ~ 'dfxpath=' ~  path('gast_termin_edit' , { 'id': termin.id, 'init': termin.init  })}}">{{ 'Termin bearbeiten'|trans }}</a>.</p>
<p><a class="delete" href="{{ frontendUrlQ }}dfxpath={{ path('gast_termin_delete' , { 'id': termin.id, 'init': termin.init  })}}" title='Datensatz "{{ termin.titel }}" löschen'>{{ 'Termin loeschen'|trans }}</a>.</p>
{% endblock body %}

