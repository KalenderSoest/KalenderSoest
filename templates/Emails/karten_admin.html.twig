{% extends 'Emails/base_termin.html.twig' %}
{% block body %}
<h3>{{ 'karten'|trans }} {{ 'fuer'|trans }}</h3>
<p><strong>{{ termin.titel|raw }}</strong><br>
{{ strDate }} {% if strTime !='' %}{{ strTime }}{% endif %}</p>
<p>
{% if strLokal != NULL %}{{ strLokal|raw }}<br>{% endif %}
{% if strStrasse != NULL %}{{ strStrasse|raw }}<br>{% endif %}
{% if strOrt !=NULL %}{{ strOrt|raw }}<br>{% endif %}
</p>
<p><a href="{{ frontendUrlQ }}dfxpath={{ path('detail', { 'id': karten.termin.id, 'kid': konf.id }) }}">{{ 'termin ansehen'|trans }}</a></p>

<h4>{{ 'karten'|trans }} {{ 'von'|trans }}</h4>
<table width="800">
  <tr>
    <td>{{ 'anzahl'|trans }}</td>
    <td>{{ karten.anzahl }}</td>
  </tr>
  <tr>
    <td>{{ 'nachname'|trans }}</td>
    <td>{{ karten.nachname }}</td>
  </tr>
  <tr>
    <td>{{ 'vorname'|trans }}</td>
    <td>{{ karten.vorname }}</td>
  </tr>
  <tr>
    <td>{{ 'strasse'|trans }}</td>
    <td>{{ karten.strasse }}</td>
  </tr>
  <tr>
    <td>{{ 'plz'|trans }} {{ 'ort'|trans }}</td>
    <td>{{ karten.plz }} {{ karten.ort }}</td>
  </tr>
  <tr>
    <td>{{ 'email'|trans }}</td>
    <td>{{ karten.email }}</td>
  </tr>
  <tr>
    <td>{{ 'telefon'|trans }}</td>
    <td>{{ karten.tel}}</td>
  </tr>
  <tr>
    <td>{{ 'mobil'|trans }}</td>
    <td>{{ karten.mobil}}</td>
  </tr>
  <tr>
    <td>{{ 'nachricht'|trans }}</td>
    <td>{{ karten.notiz}}</td>
  </tr>
</table>
<p>{{ 'ak-text5'|trans }}</p>
{% endblock body %}

