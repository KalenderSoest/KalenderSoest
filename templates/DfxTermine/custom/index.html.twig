				<td><a title="Datensatz bearbeiten" href="{{ path('termine_edit', { 'id': termin.id }) }}"><i class="fa-solid fa-pen-to-square"> </i></a></td>
				<td><a href="{{ path('termine_copy', { 'id': termin.id }) }}" title="Datensatz {{ termin.titel }} kopieren"><i class="fa-solid fa-copy"> </i></a></td>
