{% block javascript_onload %}
    var filterReset = document.getElementById('filterreset');
    if (filterReset) {
        filterReset.addEventListener('click', function() {
            location.href = '/admin/termine/reset';
        });
    }

    document.addEventListener('click', function(event) {
        var link = event.target.closest('.pub a');
        if (!link) {
            return;
        }

        event.preventDefault();

        var cell = link.closest('.pub');
        if (!cell) {
            return;
        }

        var state = Number(cell.dataset.state) || 0;
        var targetUrl = link.getAttribute('href');
        var prevHtml = cell.innerHTML;

        cell.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';

        fetch(targetUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(function(response) {
                return response.text();
            })
            .then(function(data) {
                if (data === 'ok') {
                    var nextState = state === 1 ? 0 : 1;
                    cell.dataset.state = String(nextState);
                    cell.innerHTML = nextState === 1 ? (cell.dataset.htmlOn || '') : (cell.dataset.htmlOff || '');
                    return;
                }

                cell.innerHTML = 'err';
            })
            .catch(function() {
                cell.innerHTML = prevHtml;
            });
    });

    document.addEventListener('click', function(event) {
        var toggleButton = event.target.closest('.dfx-toggle-all');
        if (toggleButton) {
            var toggleForm = toggleButton.closest('form');
            if (!toggleForm) {
                return;
            }

            var checkboxes = Array.prototype.slice.call(toggleForm.querySelectorAll('input[name="selectedIds[]"]'));
            if (!checkboxes.length) {
                return;
            }

            var allChecked = checkboxes.every(function(checkbox) {
                return checkbox.checked;
            });

            checkboxes.forEach(function(checkbox) {
                checkbox.checked = !allChecked;
            });

            return;
        }

        var batchButton = event.target.closest('.dfx-batch-trigger');
        if (!batchButton) {
            return;
        }

        var form = batchButton.closest('form');
        if (!form) {
            return;
        }

        var checkedItems = form.querySelectorAll('input[name="selectedIds[]"]:checked');
        if (!checkedItems.length) {
            alert('Bitte zuerst mindestens einen Eintrag markieren.');
            return;
        }

        var actionField = form.querySelector('input[name="batchAction"]');
        if (!actionField) {
            return;
        }

        actionField.value = batchButton.dataset.action || '';
        form.submit();
    });

    document.addEventListener('click', function(event) {
        var pageLink = event.target.closest('.dfx-termine-section .pagination a');
        if (!pageLink) {
            return;
        }

        var section = pageLink.closest('.dfx-termine-section');
        if (!section) {
            return;
        }

        event.preventDefault();

        fetch(pageLink.href, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(function(response) {
                return response.text();
            })
            .then(function(html) {
                var parser = new DOMParser();
                var doc = parser.parseFromString(html, 'text/html');
                var replacement = doc.getElementById(section.id);

                if (!replacement) {
                    window.location.href = pageLink.href;
                    return;
                }

                section.replaceWith(replacement);
                if (window.history && window.history.replaceState) {
                    window.history.replaceState({}, '', pageLink.href);
                }
            })
            .catch(function() {
                window.location.href = pageLink.href;
            });
    });
{% endblock %}



