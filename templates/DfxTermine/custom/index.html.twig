{% extends 'Admin/' ~ backend ~ 'base_admin.html.twig' %}
{% block title 'Termine' %}
{% block pageheader 'Veranstaltungen' %}
{% block subheader 'Listenansicht' %}


{% block body -%}
{% set days = {'0':'sonntag'|trans,'1':'montag'|trans, '2':'dienstag'|trans, '3':'mittwoch'|trans, '4':'donnerstag'|trans, '5':'freitag'|trans, '6':'samstag'|trans} %}
{% set months = {'1':'januar'|trans,'2':'februar'|trans, '3':'maerz'|trans, '4':'april'|trans, '5':'mai'|trans, '6':'juni'|trans, '7':'juli'|trans, '8':'august'|trans, '9':'september'|trans, '10':'oktober'|trans, '11':'november'|trans, '12':'dezember'|trans} %}

{% block dfx_nav_filter_top %}
		<a href="{{ path('termine_new') }}">Termin hinzufügen</a>
		<hr>
        {% if konf.id == 4 %}
            <a class="btn btn-primary" href="/admin/custom/eventbrain/">Termine von Eventbrain importieren</a>
        {% elseif konf.id == 81 %}
            <a class="btn btn-primary" href="/admin/custom/kino/">Termine von Cinetixx importieren</a> Achtung, Abfrage kann drei bis fünf Minuten dauern!
        {% elseif konf.id == 134 %}
            <a class="btn btn-primary" href="/admin/custom/kirche/">Termine von Ev Termine importieren</a>
        {% endif %}
        <hr>
		{{ form_start(filter_form,  {'attr': {'class': ''} }) }}
		<div class="row">
		 	<div class="col-sm-6 col-md-3">
		  		{{ form_row(filter_form.datum_von) }}
		 	</div>
		  	<div class="col-sm-6 col-md-3">
		  		{{ form_row(filter_form.datum_bis) }}
		  	</div>
		  	<div class="col-sm-12 col-md-3">
		  		{{ form_row(filter_form.rubrik) }}
		 	</div>
                        {% if zielgruppe %}
                            <div class="col-sm-12 col-md-3">
                                    {{ form_row(filter_form.zielgruppe) }}
                            </div>
                        {% endif %}
                        
		</div>
		<div class="row">
			<div class="col-sm-12 col-md-6">
		  		{{ form_row(filter_form.suche) }}
		  	</div>
		    <div class="col-12 col-sm-3 col-md-2">
		  		{{ form_row(filter_form.plz) }}
		  	</div>
		  	<div class="col-sm-12 col-md-4">
		 		{{ form_row(filter_form.ort) }}
		  	</div>
		</div>
		<div class="row">
		  	<div class="col-sm-12 col-md-4">
		  		{{ form_row(filter_form.lokal) }}
		  	</div>
		
		  	<div class="col-sm-12 col-md-4">
		  		{{ form_row(filter_form.veranstalter) }}
		  	</div>
            <div class="col-sm-12 col-md-4">
                {{ form_row(filter_form.optionsRadio) }}
            </div>
		</div>
	{% if is_granted('ROLE_DFX_META') or is_granted('ROLE_DFX_GROUP') %}
	<fieldset>
    	<legend>Filter für Meta- und Gruppenkalender</legend>
		<div class="row">
		  	<div class="col-sm-6 col-md-6 ">
		  		{{ form_row(filter_form.hideSub) }}
		  	</div>
		  	<div class="col-sm-6 col-md-6">
		  		{{ form_row(filter_form.filterPub) }}
		  	</div>
		</div>
	</fieldset>	
	{% endif %}
		<div class="row">
		  <div class="col-6 col-sm-4 col-md-4">
		  {{ form_row(filter_form.submit) }}
		  </div>
		  <div class="col-6 col-sm-4 col-md-4">
		  {{ form_row(filter_form.reset) }}
		  </div>
		</div>
        {{ form_row(filter_form._token) }}
        {{ form_end(filter_form, {render_rest: false}) }}
        {% if filter != ''%}
            <hr>
            <div class="row alert-info" style="padding: 10px; margin: 20px 0">
                <div class="col-12 col-sm-10">{{ filter|raw }} </div>
                <div class="col-12 col-sm-2"><input id="filterreset" value="Filter löschen" class="btn btn-secondary form-control" type="button"></div>
            </div>
        {% endif %}


{% endblock %}
<hr>
<a href="{{ path('termine_new') }}">Termin hinzufügen</a>
<hr>
<div id="termine-published-section" class="dfx-termine-section" data-section-id="termine-published-section">
<h4>Veröffentlichte Termine ab heute</h4>
{%  if termine.getTotalItemCount == 0 %}
            Keine veröffentlichten Termine gefunden	
{% else %}

<form action="{{ path('termine_batch_action') }}" method="POST" class="dfx-batch-form">
    <input type="hidden" name="batchAction" value="">
    <input type="hidden" name="batchSection" value="published">
    <table class="table table-striped">
        <thead>
            <tr>
                <th>&nbsp;</th>
            	<th>Datum</th>
            	<th>Uhrzeit</th>
            	<th>Titel</th>
                <th>Pub</th>
                {% if konf.isMeta == true or is_granted('ROLE_DFX_META') %}
                    <th>PubMeta</th>
                {% endif %}
                {% if konf.isGroup == true or (konf.toGroup is not empty and is_granted('ROLE_DFX_GROUP')) %}
                    <th>PubGroup</th>
                {% endif %}
                <th colspan="5">Actions/Aufrufe</th>
                {% if is_granted('ROLE_ADMIN') %}
                    <th>PDF</th>
                {% endif %}
            </tr>
        </thead>
        <tbody>
        {%  if termine is not defined %}
            Keine Termine gefunden	
        {% endif %}
		{% for termin in termine %}
			{% set daynr =  termin.datumVon|date('w') %}
			{% set daynrto =  termin.datum|date('w') %}
			{% set monthnr =  termin.datumVon|date('n') %}
			{% set monthnrto =  termin.datum|date('n') %}
			{% if termin.datum == termin.datumVon %}
				{% set strDate =  "#{ days[daynr] }, #{ termin.datumVon|date('d.m.Y') } " %}
			{% else %}	
				{% set strDate =  "#{ days[daynr] }, #{ termin.datumVon|date('d') }. #{ months[monthnr] } #{ termin.datumVon|date('Y') }  bis #{ days[daynrto] }, #{ termin.datum|date('d') }. #{ months[monthnrto] } #{ termin.datum|date('Y') } " %}
			{% endif %}	
		    {% set strTime = termin.zeit != null ? "#{ termin.zeit|date('H:i') } Uhr" : "" %}
			{% set strTime = termin.zeitBis != null ?  strTime ~ " bis #{ termin.zeitBis|date('H:i') } Uhr" : "#{strTime}" %}
		    	
            <tr>
                <td><input type="checkbox" name="selectedIds[]" class="checkall" value="{{ termin.id }}" id="checkbox_{{ termin.id }}"></td>
                <td>{{ strDate }}</td>
                <td>{{ strTime }}</td>
                <td>{{ termin.titel|raw }} </td>
                <td>{% if is_granted('ROLE_DFX_PUB')  %}<a title="Datensatz deaktivieren" href="{{ path('termine_unpub', { 'id': termin.id }) }}"><i class="fa-solid fa-eye"> </i></a>{%  endif %}</td>
                {% if konf.isMeta == true or is_granted('ROLE_DFX_META') %}
                	<td class="pub" id="meta_{{ termin.id }}_{{ termin.pubMeta }}"
						data-state="{{ termin.pubMeta ? 1 : 0 }}"
						data-html-on="{{ ('<a href="' ~ path('termine_unpubmeta', { 'id': termin.id }) ~ '"><i class="text-success fa-solid fa-square-check"></i> <i class="fa-solid fa-right-left"></i></a>')|e('html_attr') }}"
						data-html-off="{{ ('<a href="' ~ path('termine_pubmeta', { 'id': termin.id }) ~ '"><i class="text-danger fa-solid fa-square-check"></i> <i class="fa-solid fa-right-left"></i></a>')|e('html_attr') }}"
					>{% if termin.pubMeta == 1 %}<a href="{{ path('termine_unpubmeta', { 'id': termin.id }) }}"><i class="text-success fa-solid fa-square-check"></i> <i class="fa-solid fa-right-left"></i></a> {% else %} <a href="{{ path('termine_pubmeta', { 'id': termin.id }) }}"><i class="text-danger fa-solid fa-square-check"></i> <i class="fa-solid fa-right-left"></i></a>{%  endif %}</td>
                {% endif %} 
                {% if konf.isGroup == true or (konf.toGroup is not empty and is_granted('ROLE_DFX_GROUP')) %}
                	<td class="pub" id="group_{{ termin.id }}_{{ termin.pubGroup }}"
						data-state="{{ termin.pubGroup ? 1 : 0 }}"
						data-html-on="{{ ('<a href="' ~ path('termine_unpubgroup', { 'id': termin.id }) ~ '"><i class="text-success fa-solid fa-square-check"></i> <i class="fa-solid fa-right-left"></i></a>')|e('html_attr') }}"
						data-html-off="{{ ('<a href="' ~ path('termine_pubgroup', { 'id': termin.id }) ~ '"><i class="text-danger fa-solid fa-square-check"></i> <i class="fa-solid fa-right-left"></i></a>')|e('html_attr') }}"
					>{% if termin.pubGroup == 1 %}<a href="{{ path('termine_unpubgroup', { 'id': termin.id }) }}"><i class="text-success fa-solid fa-square-check"></i> <i class="fa-solid fa-right-left"></i></a> {% else %} <a href="{{ path('termine_pubgroup', { 'id': termin.id }) }}"><i class="text-danger fa-solid fa-square-check"></i> <i class="fa-solid fa-right-left"></i></a>{%  endif %}</td>
                {% endif%}
				<td><a href="{{ path('termine_edit', { 'id': termin.id }) }}" title="Datensatz {{ termin.titel }} bearbeiten"><i class="fa-solid fa-pen-to-square"> </i></a></td>
				<td><a href="{{ path('termine_copy', { 'id': termin.id }) }}" title="Datensatz {{ termin.titel }} kopieren"><i class="fa-solid fa-copy"> </i></a></td>
                <td><a title="Datensatz ansehen" href="{{ termin.datefix.frontendUrl }}?dfxid={{ termin.id }}" target="_blank"><i class="fa-solid fa-globe"> </i></a></td>
                <td><a class="delete" title="Datensatz {{ termin.titel }} löschen" href="{{ path('termine_delete', { 'id': termin.id }) }}"><i class="fa-solid fa-trash-can"> </i></a></td>
                <td>{{ termin.counter }}</td>
                {% if is_granted('ROLE_ADMIN') %}
                     <td><a href="{{ path('termin_pdf', { 'id': termin.id }) }}" title="PDF erzeugen"><i class="fa-solid fa-file-pdf"> </i></a></td>
                {% endif %}
            </tr>
        {% endfor %}
        </tbody>
    </table>
    <div class="dfx-batch-actions" style="display:flex; gap:10px; flex-wrap:wrap; margin-bottom:12px;">
        <button type="button" class="btn btn-outline-secondary dfx-toggle-all">Alle markieren / demarkieren</button>
        {% if konf.isMeta == true or is_granted('ROLE_DFX_META') %}
            <button type="button" class="btn btn-secondary dfx-batch-trigger" data-action="pubmeta">Alle markierten: PubMeta</button>
        {% endif %}
        {% if konf.isGroup == true or (konf.toGroup is not empty and is_granted('ROLE_DFX_GROUP')) %}
            <button type="button" class="btn btn-secondary dfx-batch-trigger" data-action="pubgroup">Alle markierten: PubGroup</button>
        {% endif %}
        <button type="button" class="btn btn-danger dfx-batch-trigger" data-action="delete">Alle markierten löschen</button>
    </div>
    </form>
    <div class="navigation">
    	{{ knp_pagination_render(termine) }}
	</div>
	{% endif %}
    </div>
	<hr>
