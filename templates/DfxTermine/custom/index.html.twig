						data-html-off="{{ ('<a href="' ~ path('termine_pubgroup', { 'id': termin.id }) ~ '"><i class="text-danger fa-solid fa-square-check"></i> <i class="fa-solid fa-right-left"></i></a>')|e('html_attr') }}"
