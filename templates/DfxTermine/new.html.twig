{% extends 'Admin/' ~ backend ~ 'base_admin.html.twig' %}
{% block title 'Termin hinzufügen' %}
{% block pageheader 'Termin hinzufügen' %}
{% block subheader ''  %}
{% form_theme form '@Tinymce/form/tinymce_type.html.twig' %}

{% block footer %}
    {% if konf.useMap == 1 %}
    	<link href="{{ asset('js/leaflet/leaflet.css') }}" rel="stylesheet">
        <script src="{{ asset('js/leaflet/leaflet.js') }}" type="text/javascript"></script>
    {% endif %}
{% endblock footer %}
{% block javascript_onload %}
	(function() {
		var form = document.querySelector('form[name="termine"]');
		var beschreibung = document.getElementById('termine_beschreibung');
		var lead = document.getElementById('termine_lead');
		var datumListe = document.getElementById('termine_datum_s_liste');
		var datumSerie = document.getElementById('termine_datumSerie');
		var serientermin = document.getElementById('serientermin');
		var datumVon = document.getElementById('termine_datum_von');
		var online = document.getElementById('termine_online');
		var imageInfo = document.getElementById('imageInfoBlock');
		var imgCopyCheck = document.getElementById('termine_imgcopycheck');
		var imageFile = document.getElementById('termine_imageFile');

		function updateDatumVonRequired() {
			var hasSerieList = (datumListe && datumListe.value ? datumListe.value.trim() : '').length > 0;
			var hasSeriePicker = (datumSerie && datumSerie.value ? datumSerie.value.trim() : '').length > 0;
			var isSerieTab = serientermin && (serientermin.classList.contains('active') || serientermin.classList.contains('show'));
			if (datumVon) {
				if (hasSerieList || hasSeriePicker || isSerieTab) {
					datumVon.required = false;
					datumVon.removeAttribute('required');
				} else {
					datumVon.required = true;
				}
			}
		}

		updateDatumVonRequired();
		if (datumListe) {
			datumListe.addEventListener('input', updateDatumVonRequired);
			datumListe.addEventListener('change', updateDatumVonRequired);
		}
		if (datumSerie) {
			datumSerie.addEventListener('input', updateDatumVonRequired);
			datumSerie.addEventListener('change', updateDatumVonRequired);
		}
		var serTab = document.getElementById('serientermin-tab');
		var einTab = document.getElementById('einzeltermin-tab');
		if (serTab) serTab.addEventListener('shown.bs.tab', updateDatumVonRequired);
		if (einTab) einTab.addEventListener('shown.bs.tab', updateDatumVonRequired);

		{% if konf.maxLengthBeschreibung > 0 %}
		if (form) {
			form.addEventListener('submit', function(e) {
				if (beschreibung && beschreibung.value.length > {{ konf.maxLengthBeschreibung }} + 10) {
					alert("Der Text für die Beschreibung ist mit " + beschreibung.value.length + " Zeichen länger als die erlaubten {{ konf.maxLengthBeschreibung }} Zeichen.\n\nVor dem erneuten Absenden ist ein Klick ein anderes Formularfeld nötig !.");
					e.preventDefault();
					return false;
				}
			});
		}
		{% endif %}
		{% if konf.maxLengthLead > 0 %}
		if (lead) {
			lead.addEventListener('blur', function() {
				if (lead.value.length > {{ konf.maxLengthlead }} ) {
					alert("Der Text für die Kurzfassung ist mit " + lead.value.length + " Zeichen länger als die erlaubten {{ konf.maxLengthLead }} Zeichen");
				}
			});
		}
		if (form) {
			form.addEventListener('submit', function(e) {
				if (lead && lead.value.length > {{ konf.maxLengthlead }} ) {
					alert("Der Text für die Kurzfassung ist mit " + lead.value.length + " Zeichen länger als die erlaubten {{ konf.maxLengthLead }} Zeichen.\n\nVor dem erneuten Absenden ist ein Klick ein anderes Formularfeld nötig !.");
					e.preventDefault();
					return false;
				}
			});
		}
		{% endif %}

		{%  if konf.feldRegion == 1 %}
		var region = document.getElementById('termine_region');
		if (region) {
			region.addEventListener('change', function(){
				var rid = region.value ? region.value : 0;
				fetch(url + "/js/kalender/json/region/" + rid)
					.then(function(res){ return res.json(); })
					.then(function (jdata) {
						var idOrt = document.getElementById('termine_idOrt');
						var ort = document.getElementById('termine_ort');
						if (!idOrt) return;
						idOrt.innerHTML = '';
						var arrlen = jdata.length;
						if (arrlen === 1) {
							var opt = document.createElement('option');
							opt.value = jdata[0].id;
							opt.textContent = jdata[0].ort;
							idOrt.appendChild(opt);
							if (ort) ort.value = jdata[0].ort;
						} else {
							var optEmpty = document.createElement('option');
							optEmpty.value = '';
							optEmpty.textContent = 'Ort wählen';
							idOrt.appendChild(optEmpty);
							for (var i = 0; i < arrlen; i++) {
								var opt2 = document.createElement('option');
								opt2.value = jdata[i].id;
								opt2.textContent = jdata[i].ort;
								idOrt.appendChild(opt2);
							}
						}
					});
			});
		}
		{% endif %}
		{%  if konf.feldOrtdb == 1 %}
		var idOrtSel = document.getElementById('termine_idOrt');
		if (idOrtSel) {
			idOrtSel.addEventListener('change', function(){
				var regionVal = document.getElementById('termine_region');
				if (parseInt(idOrtSel.value || '0', 10) > 0 && regionVal && regionVal.value !== null) {
					fetch(url + "/js/kalender/json/ort/" + idOrtSel.value)
						.then(function(res){ return res.json(); })
						.then(function (jdata) {
							var regionEl = document.getElementById('termine_region');
							var plzEl = document.getElementById('termine_plz');
							var ortEl = document.getElementById('termine_ort');
							if (regionEl) regionEl.value = jdata.rid;
							if (plzEl) plzEl.value = jdata.plz;
							if (ortEl) ortEl.value = jdata.ort;
						});
				}
			});
		}
		{% endif %}

		var showTermine = document.getElementById('showTermine');
		if (showTermine) {
			showTermine.addEventListener('show.bs.modal', function(){
				if (datumVon && datumVon.value.length > 0) {
					fetch(url + "/admin/termine/json/check/" + datumVon.value)
						.then(function(res){ return res.text(); })
						.then(function(html){
							var liste = document.getElementById('terminliste');
							if (liste) liste.innerHTML = html;
						});
				}
			});
		}

		function toggleOnline() {
			var hideEls = document.querySelectorAll('.hideOnline');
			var showEls = document.querySelectorAll('.showOnline');
			if (online && online.checked) {
				hideEls.forEach(function(el){ el.style.display = 'none'; });
				showEls.forEach(function(el){ el.style.display = ''; });
			} else {
				hideEls.forEach(function(el){ el.style.display = ''; });
				showEls.forEach(function(el){ el.style.display = 'none'; });
			}
		}
		if (online) {
			toggleOnline();
			online.addEventListener('click', toggleOnline);
		}

		if (imageInfo) imageInfo.style.display = 'none';
		if (imageFile) {
			imageFile.addEventListener('change', function(){
				if (imageFile.value !== null) {
					if (imageInfo) imageInfo.style.display = '';
					if (imgCopyCheck) imgCopyCheck.required = true;
				} else {
					if (imageInfo) imageInfo.style.display = 'none';
					if (imgCopyCheck) imgCopyCheck.required = false;
				}
			});
		}
		if (form) {
			form.addEventListener('reset', function(){
				if (imageInfo) imageInfo.style.display = 'none';
				if (imgCopyCheck) imgCopyCheck.required = false;
			});
		}
	})();
{% endblock %}
{% block javascript_functions %}
// Initialize tooltip component
if (window.bootstrap && window.bootstrap.Tooltip) {
    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
        window.bootstrap.Tooltip.getOrCreateInstance(el);
    });
}

// Initialize popover component
if (window.bootstrap && window.bootstrap.Popover) {
    document.querySelectorAll('[data-bs-toggle="popover"]').forEach(function (el) {
        window.bootstrap.Popover.getOrCreateInstance(el);
    });
}
{% endblock %}

{% block body -%}
<div id="dfx" data-kid="{{ konf.id }}" data-dfx-url="{{ datefix_url }}" style="display:none"></div>
	{{ form_start(form) }}
  <!-- Nav tabs -->
  <div id="">
      <!-- Nav pills -->
      <ul class="nav nav-tabs" role="tablist">
          <li class="nav-item" role="presentation">
              <a class="nav-link active" id="einzeltermin-tab" data-bs-toggle="tab" data-bs-target="#einzeltermin" type="button" role="tab" aria-controls="einzeltermin" aria-selected="true">Einzeltermin</a>
          </li>
          <li class="nav-item" role="presentation">
              <a class="nav-link" id="serientermin-tab" data-bs-toggle="tab" data-bs-target="#serientermin" type="button" role="tab" aria-controls="serientermin" aria-selected="false">Serientermin</a>
          </li>
      </ul>

      <hr>

      <!-- Tab panes -->
      <div class="tab-content">
          <div class="tab-pane fade show active" id="einzeltermin" role="tabpanel" aria-labelledby="einzeltermin-tab">
              {% if error is defined %}
                  <h3><strong style="color: red">Fehler ! {{ error }}</strong></h3>
              {% endif %}
              <div class="row">
                  <div class="col-sm-6 col-md-6">
                      {{ form_row(form.datum_von) }}
                  </div>
                  <div class="col-sm-6 col-md-6">
                      {{ form_row(form.datum) }}
                  </div>
              </div>
              <div class="row">
                  <div class="col-sm-6 col-md-12">
                      <h4>Eingabe Einzeltermine</h4><p>Einzeltermine sind Veranstaltungen, die einmalig an einem Tag stattfinden oder sich über mehrere Tage erstrecken, aber als eine Veranstaltung zu betrachten sind - wie zum Beispiel ein Seminar oder eine mehrtägige Reise. <strong>Mehrtägige Einzeltermine erscheinen nur mit dem Anfangsdatum im Kalender.</strong></p>
                  </div>
              </div>
          </div>
          <div class="tab-pane fade" id="serientermin" role="tabpanel" aria-labelledby="serientermin-tab">
              <div class="row">
                  <div class="col-sm-6 col-md-3">
                      {{ form_row(form.datum_s_von) }}
                  </div>
                  <div class="col-sm-6 col-md-3">
                      {{ form_row(form.datum_s_bis) }}
                  </div>
                  <div class="col-md-6">
                      &nbsp;<br>
                      {% for checkbox in form.tage.children  %}
                          <div class="form-check-inline">
                              {{ form_label(checkbox) }}
                              {{ form_widget(checkbox) }}
                              {{ form_errors(checkbox) }}
                          </div>
                      {% endfor %}
                  </div>
              </div>
              <div class="row" id="datum-liste" style="display: none">
                  <div class="col-md-12" >
                      {{ form_row(form.datum_s_liste) }}
                  </div>
              </div>
              <div class="row">
                  <div class="col-md-6">
                      {{ form_row(form.datumSerie, {'attr': {'placeholder': '📅 Datum unregelmäßiger Termin auswählen', 'autocomplete': 'off'}}) }}
                  </div>
              </div>

              <div class="row">
                  <div class="col-sm-12 col-md-12">
                      <h3>Eingabe Serientermine</h3><p>Serientermine sind Einzeltermine, die in einem bestimmten Zeitraum regelmäßig stattfinden oder sich in unregelmäßigen Abständen wiederholen. Das können Ausstellungen sein oder ein Weihnachtsmarkt, der über einen bestimmten Zeitraum täglich stattfindet. Serientermine erscheinen an allen Tagem im Kalender und können nach der Eingabe einzeln oder gebündelt bearbeitet werden.
                      <h4>Regelmäßiger Termin</h4><p>Geben Sie ein Start- und Enddatum an und markieren dann die Tage, an denen der Termin stattfindet. Die ermittelten Tage werden automatisch in das in der nächsten Zeile erscheinende Listenfeld für die regelmäßigen Serientermine eingetragen und können ggf. von Hand nachbearbeitet werden.</p>
                      <h4>Unregelmäßiger Termin</h4><p>Unregelmäßig stattfindende Termine können über den mit dem Listenfeld verknüpften Kalender erfasst werden. Klicken Sie auf die Tage, an denen der Termin erscheinen soll. Sie können die Eingabe auch über Monatsgrenzen hinweg fortsetzen, indem Sie mit den << >> Tasten die Monate wechseln.</p>
                  </div>
              </div>
          </div>
      </div>
  </div>
<fieldset>
<legend>Wann, Was & wo</legend>
    <div class="row">
    	<div class="col-sm-6 col-md-3">
    		{{ form_row(form.zeit) }}
    	</div>
    	<div class="col-sm-6 col-md-3">
