            <button type="button" id="termincheck" style="margin-top: 30px;" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#showTermine">
                Termincheck
            </button>
        </div>
    </div>
    <div class="row">
    	<div class="col-sm-12 col-md-9">
    		 {{ form_row(form.titel) }}
    	</div>
    </div>
    {%  if konf.feldSubtitel == 1 %}
