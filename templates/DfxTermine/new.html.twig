    {% if konf.useMap == 1 %}
        <div class="row hideOnline">
            <div class="col-sm-6 col-md-2">
                {{ form_row(form.bg) }}

            </div>
            <div class="col-sm-6 col-md-2">
                {{ form_row(form.lg) }}
