    {%  endif %}
    <div class="row">
    	<div class="col-sm-12 col-md-4">
    		{{ form_row(form.mail) }}
    	</div>
     </div>
     <div class="row">
    	<div class="col-sm-12 col-md-8">
    		{{ form_row(form.mailTyp) }}
    	</div>
    </div>
    {%  if konf.feldPlatzlimit == 1 %}
