    {% endif %}
    {%  if konf.feldLink == 1 %}
    <div class="row">
    	<div class="col-sm-12 col-md-4">
    		{{ form_row(form.link) }}
    	</div>
    	<div class="col-sm-12 col-md-4">
    		{{ form_row(form.linktext) }}
    	</div>
    </div>
    {% endif %}
    {%  if konf.feldTicketlink == 1 %}
    <div class="row">
    	<div class="col-sm-12 col-md-4">
    		{{ form_row(form.ticketlink) }}
    	</div>
    	<div class="col-sm-12 col-md-4">
    		{{ form_row(form.ticketlinktext) }}
    	</div>
    </div>
    {% endif %}
    </fieldset>
<fieldset class="step-6">
    <legend>Veröffentlichen & archivieren</legend>
    <div class="row">
    	{% if is_granted('ROLE_DFX_PUB')  %}
    	<div class="col-sm-12 col-md-3">
    		{{ form_row(form.pub, {'checked' : true }) }}
    	</div>
    	{% endif %}
    	<div class="col-sm-12 col-md-3">
    		{{ form_row(form.archiv) }}
    	</div>
    	{% set metaAll = konf.pubMetaAll == 1 ? true : false %}
    	{% if is_granted('ROLE_DFX_META') %}
    	<div class="col-sm-12 col-md-3">
    		{{ form_row(form.pubMeta, {'checked' : metaAll }) }}
    	</div>
    	{% elseif metaAll %}
    	<div style="display:none">
    		{{ form_widget(form.pubMeta, {'checked' : true }) }}
    	</div>
    	{%  endif %}
    	{% set groupAll = konf.pubGroupAll == 1 ? true : false %}
    	{% if is_granted('ROLE_DFX_GROUP') %}
    	<div class="col-sm-12 col-md-3">
    		{{ form_row(form.pubGroup, {'checked' : groupAll }) }}
    	</div>
    	{% elseif groupAll %}
    	<div style="display:none">
    		{{ form_widget(form.pubGroup, {'checked' : true }) }}
    	</div>
    	{% endif %}
    </div>
    </fieldset>
    <hr>
    <div class="row">
		  <div class="col-6">
		  {{ form_row(form.submit) }}
		  </div>
		  <div class="col-6">
		  {{ form_row(form.reset) }}
		  </div>
	</div>
    {{ form_row(form._token) }}
    {{ form_end(form, {'render_rest': false}) }}
    <div><br /><a href="{{ path('admin_termine') }}">Zurück zur Liste ohne zu speichern</a></div>
    <!-- The modal -->
    <div class="modal fade" id="showTermine" tabindex="-1" aria-labelledby="modalLabelLarge" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalLabelLarge">Prüfung auf Terminüberschneidungen</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" id="terminliste">Überprüfe auf vorhandene Termine ...</div>
            </div>
        </div>
    </div>
{% endblock body %}



