<?xml version="1.0" encoding="utf-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping http://doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
  <entity name="App\Entity\DfxKarten" table="pool_dfx_karten">
    <indexes>
      <index name="id_order" columns="id_order"/>
      <index name="id_termin" columns="id_termin"/>
      <index name="id_kalender" columns="id_kalender"/>
      <index name="id_kategorie" columns="id_kategorie"/>
    </indexes>
    <id name="id" type="integer" column="id">
      <generator strategy="IDENTITY"/>
    </id>
    <field name="anzahl" type="integer" column="anzahl"/>
    <field name="datum" type="datetime" column="datum"/>
    <many-to-one field="datefix" target-entity="DfxKonf">
      <join-columns>
        <join-column name="id_kalender"  on-delete="CASCADE"/>
      </join-columns>
    </many-to-one>
    <many-to-one field="termin" target-entity="DfxTermine">
      <join-columns>
        <join-column name="id_termin"  on-delete="SET NULL"/>
      </join-columns>
    </many-to-one>
    <many-to-one field="kategorie" target-entity="DfxKartenKat">
      <join-columns>
        <join-column name="id_kategorie"  on-delete="SET NULL"/>
      </join-columns>
    </many-to-one>
    <many-to-one field="order" target-entity="DfxKartenOrder">
      <join-columns>
        <join-column name="id_order"  on-delete="CASCADE"/>
      </join-columns>
    </many-to-one>
  </entity>
</doctrine-mapping>
