<?xml version="1.0" encoding="utf-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping http://doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
  <entity name="App\Entity\DfxBox" table="pool_dfx_box">
    <unique-constraints>
      <unique-constraint name="kalender_id" columns="kalender_id"/>
    </unique-constraints>
    <id name="id" type="integer" column="id">
      <generator strategy="IDENTITY"/>
    </id>
    <field name="boxItems" type="integer" column="box_items" nullable="true">
    <options>
           <option name="default">5</option>
        </options>
    </field>
    <field name="boxOrt" type="boolean" column="box_ort" nullable="true">
    <options>
           <option name="default">1</option>
        </options>
    </field>
    <field name="boxDatum" type="boolean" column="box_datum" nullable="true">
    <options>
           <option name="default">1</option>
        </options>
    </field>
    <field name="boxUhr" type="boolean" column="box_uhr" nullable="true">
    <options>
           <option name="default">1</option>
        </options>
    </field>
    <field name="boxTitel" type="boolean" column="box_titel" nullable="true">
    <options>
           <option name="default">1</option>
        </options>
    </field>
      <field name="boxSubtitel" type="boolean" column="box_subtitel" nullable="true">
          <options>
              <option name="default">0</option>
          </options>
      </field>
    <field name="boxLead" type="boolean" column="box_lead" nullable="true">
    <options>
           <option name="default">0</option>
        </options>
    </field>
    <field name="boxBeschreibung" type="boolean" column="box_beschreibung" nullable="true">
    <options>
           <option name="default">0</option>
        </options>
    </field>
    <field name="boxLokal" type="boolean" column="box_lokal" nullable="true">
    <options>
           <option name="default">1</option>
        </options>
    </field>
    <field name="boxVeranstalter" type="boolean" column="box_veranstalter" nullable="true">
    <options>
           <option name="default">0</option>
        </options>
    </field>
    <field name="boxImage" type="boolean" column="box_image" nullable="true">
    <options>
           <option name="default">0</option>
        </options>
    </field>
    <field name="boxCss" type="text" column="box_css" nullable="true"/>
    <field name="boxTerminUrl"  column="box_termin_url" length="255" nullable="true"/>
    <field name="boxTarget"  column="box_target" length="255" nullable="true"/>

    <many-to-one field="datefix" target-entity="DfxKonf">
      <join-columns>
        <join-column name="kalender_id"  on-delete="CASCADE"/>
      </join-columns>
    </many-to-one>
  </entity>
</doctrine-mapping>
