<?xml version="1.0" encoding="utf-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping http://doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
  <entity name="App\Entity\DfxReminder" table="pool_dfx_reminder">
    <indexes>
      <index name="kalender_id" columns="kalender_id"/>
      <index name="termin_1d" columns="termin_id"/>
    </indexes>
    <id name="id" type="integer" column="id">
      <generator strategy="IDENTITY"/>
    </id>
    <field name="datum" type="date" column="datum"/>
    <field name="email"  column="email" length="150"/>
    <field name="code"  column="code" length="150" nullable="true"/>
    <field name="datenschutz" type="boolean" column="datenschutz" nullable="true"/>
    <many-to-one field="termin" target-entity="DfxTermine">
      <join-columns>
        <join-column name="termin_id"  on-delete="CASCADE"/>
      </join-columns>
    </many-to-one>
    <many-to-one field="datefix" target-entity="DfxKonf">
      <join-columns>
        <join-column name="kalender_id"  on-delete="CASCADE"/>
      </join-columns>
    </many-to-one>
  </entity>
</doctrine-mapping>
